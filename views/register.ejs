<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Registro</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: var(--bg-color); padding: 2rem 0; }
        .auth-container { background: white; padding: 3rem; border-radius: 16px; box-shadow: var(--shadow-md); width: 100%; max-width: 500px; text-align: center; }
        .logo { justify-content: center; margin-bottom: 2rem; font-size: 2rem; display:flex; align-items:center; gap:8px;}
        .form-group { text-align: left; margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
        .form-group input, .form-group select { width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px; outline: none; font-family: 'Inter'; }
        
        .role-selector { display: flex; gap: 1rem; margin-bottom: 2rem; }
        .role-card { flex: 1; padding: 1.5rem; border: 2px solid #ddd; border-radius: 12px; cursor: pointer; transition: 0.3s; }
        .role-card.active { border-color: var(--primary); background: rgba(46,204,113,0.05); }
        .role-card i { font-size: 2rem; color: var(--secondary); margin-bottom: 0.5rem; }
        .role-card.active i { color: var(--primary); }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo">
            <i class="fa-solid fa-leaf" style="color:var(--primary);"></i>
            <span style="font-family:'Outfit'; font-weight:800; color:var(--primary);">Kilómetro 0</span>
        </div>
        <h2 style="margin-bottom: 0.5rem;">Crea tu cuenta</h2>
        <p style="color: var(--text-light); margin-bottom: 2rem;">Únete a nuestra comunidad local</p>
        
        <div class="role-selector">
            <div class="role-card <%= role === 'cliente' ? 'active' : '' %>" onclick="selectRole('cliente')" id="card-cliente">
                <i class="fa-solid fa-basket-shopping"></i>
                <div style="font-weight:bold;">Cliente</div>
            </div>
            <div class="role-card <%= role !== 'cliente' ? 'active' : '' %>" onclick="selectRole('productor')" id="card-productor">
                <i class="fa-solid fa-tractor"></i>
                <div style="font-weight:bold;">Productor</div>
            </div>
        </div>

        <form id="registerForm" onsubmit="handleRegister(event)">
            <input type="hidden" id="role" value="<%= role %>">
            
            <div class="form-group">
                <label>Nombre Completo / Razón Social</label>
                <input type="text" id="name" required placeholder="Tu nombre">
            </div>
            <div class="form-group">
                <label>Correo Electrónico</label>
                <input type="email" id="email" required placeholder="tu@email.com">
            </div>
            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" id="password" required placeholder="••••••••">
            </div>
            
            <div id="producer-fields" style="display:<%= role === 'productor' ? 'block' : 'none' %>; background: #f9f9f9; padding: 1.5rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid #eee;">
                <h4 style="margin-bottom:1rem; color:var(--primary);"><i class="fa-solid fa-circle-check"></i> Verificación de Productor</h4>
                <div class="form-group">
                    <label>DNI / CIF</label>
                    <input type="text" id="dni" placeholder="12345678A">
                </div>
                <div class="form-group">
                    <label>Referencia Catastral</label>
                    <input type="text" id="catastral" placeholder="XXXXX...">
                </div>
                <div class="form-group">
                    <label>Dirección (Carretera y km / Calle y número)</label>
                    <input type="text" id="address" placeholder="Ej: Ctra. M-501 km 12">
                </div>
                <div class="form-group">
                    <label>Teléfono de Contacto</label>
                    <input type="tel" id="phone" placeholder="600 000 000">
                </div>
                <p style="font-size: 0.8rem; color: gray;">Un administrador verificará tu ubicación y documentos antes de habilitar tu tienda local.</p>
            </div>
            
            <button class="btn btn-primary" type="submit" style="width: 100%;">Registrarme</button>
        </form>
        
        <p style="margin-top: 2rem; color: var(--text-light);">
            ¿Ya tienes cuenta? <a href="/login" style="color: var(--primary); font-weight: bold;">Inicia Sesión</a>
        </p>
        <p style="margin-top: 1rem;">
            <a href="/" style="font-size:0.9rem; color:gray;"><i class="fa-solid fa-arrow-left"></i> Volver a inicio</a>
        </p>
    </div>

    <script>
        function selectRole(role) {
            document.getElementById('role').value = role;
            document.getElementById('card-cliente').classList.remove('active');
            document.getElementById('card-productor').classList.remove('active');
            document.getElementById('card-' + role).classList.add('active');
            
            document.getElementById('producer-fields').style.display = (role === 'productor') ? 'block' : 'none';
        }

        function handleRegister(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const name = document.getElementById('name').value;
            const role = document.getElementById('role').value;
            
            const payload = {
                name, email, role,
                dni: document.getElementById('dni') ? document.getElementById('dni').value : '',
                catastral: document.getElementById('catastral') ? document.getElementById('catastral').value : '',
                address: document.getElementById('address') ? document.getElementById('address').value : '',
                phone: document.getElementById('phone') ? document.getElementById('phone').value : ''
            };

            fetch('/api/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            }).then(r=>r.json()).then(() => {
                localStorage.setItem('km0_user', JSON.stringify({ email: email, name: name, role: role }));
                if(role === 'productor') window.location.href = '/producer-app';
                else window.location.href = '/';
            });
        }
    </script>
</body>
</html>
