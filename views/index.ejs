<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Tienda</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { background: #f4f6f8; overflow: hidden; }
        .dashboard { display: grid; grid-template-columns: 250px 1fr; height: 100vh; }
        
        .side-nav { background: white; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; border-right: 1px solid #eee; }
        .side-nav .logo { margin-bottom: 2rem; }
        .nav-item { padding: 1rem; border-radius: 12px; cursor: pointer; font-weight: 600; color: var(--secondary); display: flex; align-items: center; gap: 12px; transition: 0.3s; }
        .nav-item:hover, .nav-item.active { background: var(--primary); color: white; }
        
        .main-content { padding: 2rem; overflow-y: auto; position: relative; }
        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; background: white; padding: 1rem 2rem; border-radius: 16px; box-shadow: var(--shadow-sm); }
        .search-box { display: flex; align-items: center; background: #f0f2f5; padding: 0.8rem 1rem; border-radius: 12px; width: 400px; }
        .search-box input { border: none; background: transparent; outline: none; margin-left: 10px; width: 100%; font-family: 'Inter'; }
        
        .view-panel { display: none; animation: fadeIn 0.4s ease; }
        .view-panel.active { display: block; }
        
        .map-frame { height: calc(100vh - 180px); width: 100%; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); border: 4px solid white; position: relative;}
        #map { height: 100%; width: 100%; }
        
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
        .produce-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); transition: 0.3s; border: 1px solid #f0f0f0;}
        .produce-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-md); border-color: var(--primary); }
        .produce-card img { width: 100%; height: 200px; object-fit: cover; }
        .produce-info { padding: 1.5rem; }
        .produce-info h4 { margin-bottom: 0.5rem; font-size: 1.2rem; }
        .producer-link { color: var(--text-light); font-size: 0.9rem; margin-bottom: 1rem; display: block; cursor: pointer; transition: 0.3s; }
        .producer-link:hover { color: var(--primary); text-decoration: underline; }
        
        .cart-sidebar { position: fixed; right: -400px; top: 0; width: 400px; height: 100vh; background: white; box-shadow: -5px 0 30px rgba(0,0,0,0.1); z-index: 3000; transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; flex-direction: column; }
        .cart-sidebar.open { right: 0; }
        .cart-header { padding: 2rem; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        .cart-body { flex: 1; padding: 2rem; overflow-y: auto; }
        .cart-footer { padding: 2rem; border-top: 1px solid #eee; background: #f9f9f9; }
        
        .cart-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px dashed #eee; padding-bottom: 1rem; }
        .cart-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 2999; display: none; backdrop-filter: blur(3px); }
        .cart-backdrop.open { display: block; }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="side-nav">
            <div class="logo">
                <i class="fa-solid fa-leaf"></i>
                <span>Kilómetro 0</span>
            </div>
            
            <div class="nav-item active" onclick="switchView('map-view', this)">
                <i class="fa-solid fa-map-location-dot"></i> Vista Mapa
            </div>
            <div class="nav-item" onclick="switchView('products-view', this)">
                <i class="fa-solid fa-boxes-stacked"></i> Ver Productos
            </div>
            <div class="nav-item" onclick="window.location.href='/about'">
                <i class="fa-solid fa-circle-info"></i> Información
            </div>
        </div>

        <div class="main-content">
            <div class="top-bar">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass" style="color: gray;"></i>
                    <input type="text" id="globalSearch" placeholder="Buscar tomates, queso, granjas...">
                </div>
                
                <div style="display:flex; gap:1.5rem; align-items:center;">
                    <button class="btn btn-outline" onclick="toggleCart()" style="border-radius: 50%; width: 45px; height: 45px; padding: 0; position: relative;">
                        <i class="fa-solid fa-basket-shopping"></i>
                        <span id="cartBadge" style="position:absolute; top:-5px; right:-5px; background:var(--primary); color:white; border-radius:50%; width:20px; height:20px; font-size:0.7rem; display:flex; align-items:center; justify-content:center;">0</span>
                    </button>
                    
                    <div id="authContainer">
                        <a href="/login" class="btn btn-secondary" style="padding: 0.5rem 1rem;">Entrar</a>
                    </div>
                </div>
            </div>

            <div id="map-view" class="view-panel active">
                <div class="map-frame">
                    <div id="map"></div>
                </div>
            </div>

            <div id="products-view" class="view-panel">
                <h2 style="margin-bottom: 2rem;">Nuestra Despensa</h2>
                <div class="products-grid" id="productsGrid"></div>
            </div>
        </div>
    </div>

    <div class="cart-backdrop" onclick="toggleCart()"></div>
    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h2><i class="fa-solid fa-basket-shopping"></i> Tu Cesta</h2>
            <i class="fa-solid fa-xmark" style="font-size: 1.5rem; cursor:pointer;" onclick="toggleCart()"></i>
        </div>
        <div class="cart-body" id="cartItems">
            <p style="color: gray;">Tu cesta está vacía.</p>
        </div>
        <div class="cart-footer" id="cartFooter">
            <h3 style="display: flex; justify-content: space-between; margin-bottom: 1rem;">Total: <span id="cartTotal">0.00€</span></h3>
            <button class="btn btn-primary" style="width: 100%;" onclick="checkout()">Tramitar Reserva</button>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        // Server-Side Injected Data
        const productsData = <%- JSON.stringify(products) %>;
        
        const userStr = localStorage.getItem('km0_user');
        if(userStr) {
            const user = JSON.parse(userStr);
            document.getElementById('authContainer').innerHTML = `
                <div style="font-weight:600; color:var(--text-dark); cursor:pointer;" onclick="logout()">
                    <i class="fa-solid fa-circle-user" style="color:var(--primary); font-size:1.2rem; margin-right:5px;"></i> ${user.name}
                    <span style="font-size:0.8rem; color:gray; display:block;">Cerrar sesión</span>
                </div>
            `;
        }

        function logout() { localStorage.removeItem('km0_user'); window.location.reload(); }

        function switchView(viewId, element) {
            document.querySelectorAll('.view-panel').forEach(v => v.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(v => v.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            if(element) element.classList.add('active');
            if(viewId === 'map-view') setTimeout(() => map.invalidateSize(), 100);
        }

        let cart = [];
        const sidebar = document.getElementById('cartSidebar');
        const backdrop = document.querySelector('.cart-backdrop');

        function toggleCart() { sidebar.classList.toggle('open'); backdrop.classList.toggle('open'); }

        function addToCart(id) {
            const product = productsData.find(p => p.id === id);
            cart.push(product);
            updateCartUI();
            if(!sidebar.classList.contains('open')) toggleCart();
        }

        function updateCartUI() {
            document.getElementById('cartBadge').innerText = cart.length;
            const body = document.getElementById('cartItems');
            if(cart.length === 0) {
                body.innerHTML = '<p style="color: gray;">Tu cesta está vacía. Selecciona productos del mapa o catálogo.</p>';
            } else {
                let html = '';
                let total = 0;
                cart.forEach((p, index) => {
                    total += p.price;
                    html += `
                        <div class="cart-item">
                            <div>
                                <h4 style="margin:0;">${p.name}</h4>
                                <span style="font-size:0.8rem; color:gray;">${p.producer_name}</span>
                            </div>
                            <div style="font-weight:bold; color:var(--primary);">${p.price.toFixed(2)}€</div>
                        </div>
                    `;
                });
                body.innerHTML = html;
                document.getElementById('cartTotal').innerText = total.toFixed(2) + '€';
            }
        }

        function checkout() {
            if(cart.length === 0) return alert('La cesta está vacía');
            fetch('/api/orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: cart, client_id: null })
            }).then(r=>r.json()).then(data => {
                document.getElementById('cartItems').innerHTML = `
                    <div style="text-align:center; padding: 2rem 0;">
                        <i class="fa-solid fa-circle-check" style="font-size:4rem; color:var(--primary); margin-bottom:1rem;"></i>
                        <h2>¡Reserva Confirmada!</h2>
                        <div id="qrcode-container" style="display:flex; justify-content:center; margin: 1.5rem 0; padding:10px; background:white; border-radius:12px; box-shadow:0 5px 15px rgba(0,0,0,0.05);"></div>
                        <p style="color:gray; font-size:0.9rem;">Referencia: ${data.qr_code}</p>
                    </div>
                `;
                
                // Generar QR Real en el contenedor
                new QRCode(document.getElementById("qrcode-container"), {
                    text: data.qr_code,
                    width: 180,
                    height: 180,
                    colorDark : "#27ae60", // Un tono verde más oscuro para contraste
                    colorLight : "#ffffff",
                    correctLevel : QRCode.CorrectLevel.M
                });
                document.getElementById('cartFooter').style.display = 'none';
                cart = [];
                document.getElementById('cartBadge').innerText = '0';
            });
        }

        // Map rendering
        const map = L.map('map').setView([40.4168, -3.7038], 6);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);

        productsData.forEach(p => {
            const marker = L.marker([p.lat, p.lng]).addTo(map);
            marker.bindPopup(`
                <div style="text-align: center; width: 180px;">
                    <img src="${p.image_url}" style="width:100%; height:100px; object-fit:cover; border-radius:8px; margin-bottom:10px;">
                    <b style="cursor:pointer; color:var(--secondary);" onclick="window.location.href='/producer-profile?id=${p.producer_id}'">${p.producer_name}</b><br>
                    ${p.name}<br>
                    <span style="color: var(--primary); font-weight: bold; font-size:1.1rem;">${p.price.toFixed(2)}€</span>
                    <br>
                    <button onclick="addToCart(${p.id})" class="btn btn-primary" style="margin-top:10px; width:100%; padding: 0.5rem;">+ Atrápalo</button>
                </div>
            `);
        });

        function renderProductsGrid(products) {
            const grid = document.getElementById('productsGrid');
            grid.innerHTML = '';
            products.forEach(p => {
                grid.innerHTML += `
                    <div class="produce-card">
                        <img src="${p.image_url}" alt="${p.name}">
                        <div class="produce-info">
                            <h4>${p.name}</h4>
                            <span class="producer-link" onclick="window.location.href='/producer-profile?id=${p.producer_id}'"><i class="fa-solid fa-location-dot"></i> De ${p.producer_name}</span>
                            <div style="display:flex; justify-content:space-between; align-items:center;">
                                <span style="font-weight:bold; font-size:1.2rem; color:var(--primary);">${p.price.toFixed(2)}€</span>
                                <button onclick="addToCart(${p.id})" class="btn btn-primary" style="padding: 0.4rem 0.8rem;">+ Cesta</button>
                            </div>
                        </div>
                    </div>
                `;
            });
        }
        renderProductsGrid(productsData);

        // Global Search
        document.getElementById('globalSearch').addEventListener('input', (e) => {
            const text = e.target.value.toLowerCase();
            const filtered = productsData.filter(p => p.name.toLowerCase().includes(text) || p.producer_name.toLowerCase().includes(text));
            renderProductsGrid(filtered);
            if(document.getElementById('map-view').classList.contains('active') && text.length > 2) {
                switchView('products-view', document.querySelectorAll('.nav-item')[1]);
            }
        });
    </script>
</body>
</html>
