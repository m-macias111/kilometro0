<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Kilómetro 0 | Administración</title>
    <style>
        body { background-color: #f0f2f5; }
        .dashboard-container { max-width: 1100px; margin: 2rem auto; display: grid; grid-template-columns: 280px 1fr; gap: 2rem; padding: 0 1rem; }
        .kpi-bar { max-width: 1100px; margin: 2rem auto 0; padding: 0 1rem; display: grid; grid-template-columns: repeat(5, 1fr); gap: 1rem; }
        .kpi-card { background: white; padding: 1.2rem; border-radius: 12px; box-shadow: var(--shadow-sm); text-align: center; border-top: 3px solid #34495e; }
        .kpi-card .kpi-value { font-size: 2rem; font-weight: 800; color: #34495e; line-height: 1; margin-bottom: 0.3rem; }
        .kpi-card .kpi-label { font-size: 0.8rem; color: gray; font-weight: 600; }
        .menu-bar { background: white; padding: 2rem 1.5rem; border-radius: 16px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem; height: fit-content; }
        .menu-item { padding: 1rem; border-radius: 8px; cursor: pointer; transition: 0.3s; font-weight: 600; color: var(--secondary); display: flex; align-items: center; gap: 10px; }
        .menu-item:hover, .menu-item.active { background: #34495e; color: white; }
        .content-area { background: white; padding: 2rem; border-radius: 16px; box-shadow: var(--shadow-sm); min-height: 500px; }
        .content-panel { display: none; }
        .content-panel.active { display: block; animation: fadeIn 0.4s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .list-group { display: flex; flex-direction: column; gap: 1rem; }
        .list-item { border: 1px solid #ddd; padding: 1.5rem; border-radius: 12px; display: flex; justify-content: space-between; align-items: center; transition: 0.3s; }
        .list-item:hover { border-color: #34495e; }
        .badge { padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.8rem; font-weight: bold; }
        .badge-warning { background: #f39c12; color: white; }
        .badge-success { background: #2ecc71; color: white; }
        .btn-block { background: transparent; border: 2px solid red; color: red; }
        .btn-block:hover { background: red; color: white; }
    </style>
</head>
<body>
    <nav class="navbar" style="position:static; background:#34495e; color:white;">
        <div class="logo" style="color:white;">
            <i class="fa-solid fa-shield-halved"></i>
            <span>Administración Kilómetro 0</span>
        </div>
        <div class="nav-links" style="display:flex; align-items:center; gap:0.75rem;">
            <span id="userName" style="font-weight:600; color:white;"></span>
            <button onclick="logoutAdmin()" style="background:#e74c3c; color:white; border:none; padding:0.5rem 1rem; border-radius:8px; font-weight:700; cursor:pointer; font-family:inherit; font-size:0.9rem; display:flex; align-items:center; gap:6px; transition:0.2s;" onmouseover="this.style.background='#c0392b'" onmouseout="this.style.background='#e74c3c'"><i class="fa-solid fa-right-from-bracket"></i> Cerrar Sesión</button>
        </div>
    </nav>

    <!-- KPIs -->
    <div class="kpi-bar" id="kpiBar">
        <div class="kpi-card"><div class="kpi-value" id="kpi-producers">–</div><div class="kpi-label"><i class="fa-solid fa-tractor"></i> Productores</div></div>
        <div class="kpi-card" style="border-top-color:#f39c12;"><div class="kpi-value" id="kpi-pending" style="color:#f39c12;">–</div><div class="kpi-label"><i class="fa-solid fa-clock"></i> Pendientes aprob.</div></div>
        <div class="kpi-card"><div class="kpi-value" id="kpi-clients">–</div><div class="kpi-label"><i class="fa-solid fa-users"></i> Clientes</div></div>
        <div class="kpi-card" style="border-top-color:#2ecc71;"><div class="kpi-value" id="kpi-today" style="color:#2ecc71;">–</div><div class="kpi-label"><i class="fa-solid fa-receipt"></i> Pedidos hoy</div></div>
        <div class="kpi-card" style="border-top-color:#1a7a3a;"><div class="kpi-value" id="kpi-revenue" style="color:#1a7a3a; font-size:1.5rem;">–</div><div class="kpi-label"><i class="fa-solid fa-euro-sign"></i> Ingresos totales</div></div>
    </div>

    <div class="dashboard-container">
        <div class="menu-bar">
            <div class="menu-item active" onclick="switchTab('tab-producers')"><i class="fa-solid fa-users"></i> Gestor Productores</div>
            <div class="menu-item" onclick="switchTab('tab-clients')"><i class="fa-solid fa-user"></i> Gestor Clientes</div>
            <div class="menu-item" onclick="switchTab('tab-orders')"><i class="fa-solid fa-receipt"></i> Logs de Transacciones</div>
        </div>

        <div class="content-area">
            <div id="tab-producers" class="content-panel active">
                <h2 style="margin-bottom: 2rem;">Validación de Productores</h2>
                <div class="list-group">
                    <% producers.forEach(function(p) { %>
                        <div class="list-item" style="align-items:flex-start;">
                            <div style="display:flex; gap:1rem;">
                                <% if(p.profileImage) { %>
                                    <img src="<%= p.profileImage %>" style="width:60px; height:60px; border-radius:50%; object-fit:cover; border:2px solid #eee; flex-shrink:0;">
                                <% } else { %>
                                    <div style="width:60px; height:60px; border-radius:50%; background:#ddd; display:flex; align-items:center; justify-content:center; color:gray; flex-shrink:0;"><i class="fa-solid fa-tractor"></i></div>
                                <% } %>
                                <div>
                                    <h4 style="margin:0 0 5px 0;"><%= p.name %> <%= p.lastName || '' %> <span style="font-size:0.9rem; color:gray; font-weight:normal;">(<%= p.email %>)</span></h4>
                                    <p style="margin:0; font-size:0.9rem; color:gray;"><i class="fa-solid fa-location-dot"></i> <%= p.locality %> | <i class="fa-solid fa-phone"></i> <%= p.phone %></p>
                                    <% if(p.history) { %> <p style="font-size:0.85rem; margin-top:5px; color:#555;"><i>"<%= p.history %>"</i></p> <% } %>
                                    <% if(!p.verified) { %>
                                        <div style="margin-top:10px; background:#f9f9f9; padding:10px; border-radius:8px; border:1px solid #eee;">
                                            <p style="margin:0 0 5px 0; font-size:0.85rem;"><strong>DNI:</strong> <%= p.dni %></p>
                                            <p style="margin:0; font-size:0.85rem;"><strong>Ref. Catastral:</strong> <%= p.catastral %></p>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                            <div style="text-align: right; display:flex; flex-direction:column; gap:0.5rem; align-items:flex-end;">
                                <div>
                                    <% if(p.verified) { %>
                                        <span class="badge badge-success"><i class="fa-solid fa-check"></i> Verificado</span>
                                    <% } else { %>
                                        <span class="badge badge-warning" id="badge-<%= p.id %>"><i class="fa-solid fa-clock"></i> Pendiente</span>
                                    <% } %>
                                </div>
                                <div style="display:flex; gap:0.5rem; margin-top:10px; align-items:center;">
                                    <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem;" onclick="window.open('/producer-profile?id=<%= p.id %>&from=admin', '_blank')">Ver Perfil</button>
                                    <% if(!p.verified) { %>
                                        <button class="btn btn-primary" id="btn-<%= p.id %>" style="padding:0.3rem 0.8rem; background:#34495e; border:none; font-size:0.8rem;" onclick="verifyProducer(<%= p.id %>)">Aprobar</button>
                                    <% } %>
                                    <% if(p.profileImage) { %>
                                        <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem;" onclick="removePhoto(<%= p.id %>)">Borrar Foto</button>
                                    <% } %>
                                    <% if(p.isBlocked) { %>
                                        <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem; color:green; border-color:green;" onclick="toggleBlock('productor', <%= p.id %>, false)">Desbloquear</button>
                                    <% } else { %>
                                        <button class="btn btn-block" style="padding:0.3rem 0.8rem; font-size:0.8rem;" onclick="toggleBlock('productor', <%= p.id %>, true)">Bloquear</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    <% if(producers.length === 0) { %>
                        <p>No hay productores en el sistema.</p>
                    <% } %>
                </div>
            </div>

            <div id="tab-clients" class="content-panel">
                <h2 style="margin-bottom: 2rem;">Perfiles de Clientes</h2>
                <div class="list-group">
                    <% clients.forEach(function(c) { %>
                        <div class="list-item">
                            <div>
                                <h4 style="margin:0 0 5px 0;"><%= c.name %> <%= c.lastName || '' %></h4>
                                <p style="margin:0; font-size:0.9rem; color:gray;"><i class="fa-solid fa-envelope"></i> <%= c.email %></p>
                            </div>
                            <div style="text-align: right;">
                                <% if(c.isBlocked) { %>
                                    <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem; color:green; border-color:green;" onclick="toggleBlock('cliente', <%= c.id %>, false)">Desbloquear</button>
                                <% } else { %>
                                    <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem; color:red; border-color:red;" onclick="toggleBlock('cliente', <%= c.id %>, true)">Bloquear</button>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                    <% if(clients.length === 0) { %>
                        <p style="color:gray;">No hay clientes registrados en el sistema.</p>
                    <% } %>
                </div>
            </div>

            <div id="tab-orders" class="content-panel">
                <h2 style="margin-bottom: 2rem;">Monitor Global de Reservas</h2>
                <div class="list-group">
                    <% orders.forEach(function(o) { %>
                        <div class="list-item">
                            <div>
                                <h4 style="margin:0 0 5px 0;"><i class="fa-solid fa-qrcode"></i> <%= o.qr_code %></h4>
                                <p style="margin:0; font-size:0.9rem; color:gray;">Artículos: <%= o.items.length %></p>
                            </div>
                            <div style="text-align: right;">
                                <strong style="font-size:1.2rem; color:var(--primary);"><%= o.total_price.toFixed(2) %>€</strong><br>
                                <span style="font-size:0.8rem; color:gray;"><%= o.status %></span><br>
                                <% if(o.status !== 'CANCELLED') { %>
                                    <button class="btn btn-outline" style="padding:0.3rem 0.8rem; font-size:0.8rem; color:red; border-color:red; margin-top:5px;" onclick="cancelOrder('<%= o.order_id %>')">Cancelar</button>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                    <% if(orders.length === 0) { %>
                        <p style="color:gray;">Aún no se ha realizado ninguna transacción en la plataforma.</p>
                    <% } %>
                </div>
            </div>
            
        </div>
    </div>

    <script>
        const userStr = localStorage.getItem('km0_user');
        if (userStr) {
            const user = JSON.parse(userStr);
            if (user.role !== 'admin') window.location.href = '/';
            document.getElementById('userName').innerText = "Hola, " + user.name;
        } else {
            window.location.href = '/login';
        }

        // Cargar KPIs
        fetch('/api/admin/kpis')
        .then(r => r.json())
        .then(data => {
            if (!data.success) return;
            document.getElementById('kpi-producers').innerText = data.totalProducers;
            document.getElementById('kpi-pending').innerText = data.pendingProducers;
            document.getElementById('kpi-clients').innerText = data.totalClients;
            document.getElementById('kpi-today').innerText = data.ordersToday;
            document.getElementById('kpi-revenue').innerText = data.totalRevenue.toFixed(0) + '€';
        }).catch(() => {});

        function logoutAdmin() {
            fetch('/api/logout', { method: 'POST' }).then(() => {
                localStorage.removeItem('km0_user');
                window.location.href = '/';
            });
        }

        function switchTab(tabId, updateHistory = true) {
            document.querySelectorAll('.content-panel').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            
            const panel = document.getElementById(tabId);
            if (panel) panel.classList.add('active');
            
            const menuItem = document.querySelector(`[onclick*="switchTab('${tabId}')"]`);
            if (menuItem) menuItem.classList.add('active');

            if (updateHistory) {
                history.pushState({ tab: tabId }, '', '#' + tabId);
            }
        }

        window.addEventListener('popstate', (event) => {
            if (event.state && event.state.tab) {
                switchTab(event.state.tab, false);
            } else {
                const hash = window.location.hash.substring(1);
                if (hash && document.getElementById(hash)) {
                    switchTab(hash, false);
                } else {
                    switchTab('tab-producers', false); // Default for admin
                }
            }
        });

        window.addEventListener('DOMContentLoaded', () => {
            const hash = window.location.hash.substring(1);
            if (hash && document.getElementById(hash)) {
                switchTab(hash, false);
            } else {
                history.replaceState({ tab: 'tab-producers' }, '', '#tab-producers');
            }
        });

        function verifyProducer(id) {
            if(!confirm('¿Estás seguro de verificar la veracidad de los documentos de este productor?')) return;
            
            fetch('/api/producers/' + id + '/verify', { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    document.getElementById('badge-' + id).className = 'badge badge-success';
                    document.getElementById('badge-' + id).innerHTML = '<i class="fa-solid fa-check"></i> Verificado';
                    document.getElementById('btn-' + id).style.display = 'none';
                }
            });
        }

        function toggleBlock(type, id, block) {
            if(!confirm(`¿Estás seguro de ${block ? 'bloquear' : 'desbloquear'} a este ${type}?`)) return;
            fetch('/api/admin/block', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ type, id, block })
            }).then(() => window.location.reload());
        }

        function removePhoto(id) {
            if(!confirm('¿Estás seguro de eliminar la foto de perfil de este productor por ser inapropiada?')) return;
            fetch('/api/admin/remove-photo', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ id })
            }).then(() => window.location.reload());
        }

        function cancelOrder(order_id) {
            if(!confirm('¿Estás seguro de cancelar esta transacción?')) return;
            fetch('/api/admin/cancel-order', {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ order_id })
            }).then(() => window.location.reload());
        }
    </script>
    <%- include('partials/footer') %>
</body>
</html>
