<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Kilómetro 0 | <%= producer ? producer.name : 'Productor' %></title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body { background: #f4f6f8; overflow: hidden; }
        .dashboard { display: grid; grid-template-columns: 250px 1fr; height: 100vh; }
        
        <% if(from === 'admin') { %>
        .side-nav { background: linear-gradient(180deg, #2c3e50 0%, #1a252f 100%); padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
        <% } else { %>
        .side-nav { background: linear-gradient(180deg, #1a7a3a 0%, #145a2b 100%); padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
        <% } %>
        .side-nav .logo { margin-bottom: 2rem; color: white; }
        .side-nav .logo i { color: <% if(from === 'admin') { %>rgba(255,255,255,0.6)<% } else { %>#8fff8f<% } %>; }
        .side-nav .logo span { color: white; }
        .nav-item { padding: 1rem; border-radius: 12px; cursor: pointer; font-weight: 600; color: rgba(255,255,255,0.8); display: flex; align-items: center; gap: 12px; transition: 0.3s; }
        .nav-item:hover { background: rgba(255,255,255,0.2); color: white; }
        
        .main-content { padding: 2rem; overflow-y: auto; position: relative; }
        
        .producer-hero { background: white; border-radius: 16px; padding: 3rem; margin-bottom: 2rem; display: flex; gap: 2rem; align-items: center; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
        .producer-hero::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(90deg, #1a7a3a, #8bc34a); }
        .producer-avatar { width: 120px; height: 120px; background: var(--primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: bold; flex-shrink: 0; }
        
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
        .produce-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid #f0f0f0; transition: 0.3s; position: relative; }
        .produce-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--primary); }
        .produce-card img { width: 100%; height: 200px; object-fit: cover; }
        .produce-card .card-badge { position:absolute; top:12px; left:12px; background:var(--primary); color:white; padding:4px 10px; border-radius:20px; font-size:0.75rem; font-weight:700; }
        .produce-card .card-price { position:absolute; top:12px; right:12px; background:rgba(0,0,0,0.7); color:white; padding:6px 12px; border-radius:20px; font-size:1rem; font-weight:800; }
        .produce-info { padding: 1.2rem 1.5rem; }
        .produce-info h4 { margin-bottom: 0.3rem; }
        .pickup-tag { display:inline-flex; align-items:center; gap:4px; font-size:0.78rem; color:#555; background:#f0f7f0; padding:3px 8px; border-radius:6px; margin-bottom:0.8rem; }

        .cart-sidebar { position: fixed; right: -400px; top: 0; width: 400px; height: 100vh; background: white; box-shadow: -5px 0 30px rgba(0,0,0,0.1); z-index: 3000; transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; flex-direction: column; }
        .cart-sidebar.open { right: 0; }
        .cart-header { padding: 2rem; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        .cart-body { flex: 1; padding: 2rem; overflow-y: auto; }
        .cart-footer { padding: 2rem; border-top: 1px solid #eee; background: #f9f9f9; }
        .cart-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px dashed #eee; padding-bottom: 1rem; }
        .cart-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 2999; display: none; backdrop-filter: blur(3px); }
        .cart-backdrop.open { display: block; }

        .floating-cart-btn { position: fixed; bottom: 2rem; right: 2rem; background: #1a7a3a; color: white; border: none; padding: 1rem 1.5rem; border-radius: 50px; font-size: 1rem; font-weight: 700; cursor: pointer; box-shadow: 0 8px 25px rgba(0,0,0,0.2); z-index: 2000; display: flex; align-items: center; gap: 10px; transition: 0.3s; font-family: 'Inter'; }
        .floating-cart-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 35px rgba(0,0,0,0.25); }
        .floating-cart-btn .badge { background: #ff6b35; color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="side-nav">
            <div class="logo" <% if(from !== 'admin') { %>onclick="window.location.href='/'" style="cursor:pointer;" title="Volver a la tienda"<% } %>>
                <i class="fa-solid fa-<%= from === 'admin' ? 'shield-halved' : 'leaf' %>"></i>
                <span>Kilómetro 0</span>
            </div>
            <% if(from === 'admin') { %>
                <div class="nav-item" onclick="window.location.href='/admin-app'">
                    <i class="fa-solid fa-arrow-left"></i> Volver al Panel
                </div>
            <% } else { %>
                <div class="nav-item" onclick="window.location.href='/'">
                    <i class="fa-solid fa-arrow-left"></i> Volver a Tienda
                </div>
                <div class="nav-item" onclick="toggleCart()">
                    <i class="fa-solid fa-basket-shopping"></i> Ver Cesta (<span id="cartCount">0</span>)
                </div>
            <% } %>
        </div>

        <div class="main-content">
            <% if(producer) { %>
                <div class="producer-hero">
                    <% if(producer.profileImage) { %>
                        <img src="<%= producer.profileImage %>" style="width:120px; height:120px; border-radius:50%; object-fit:cover; flex-shrink:0; border:3px solid #eee;">
                    <% } else { %>
                        <div class="producer-avatar"><i class="fa-solid fa-tractor"></i></div>
                    <% } %>
                    <div>
                        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= producer.name %> <%= producer.lastName || '' %></h1>
                        <p style="color: gray; font-size: 1.1rem; display:flex; align-items:center; gap:8px;">
                            <i class="fa-solid fa-location-dot" style="color:var(--primary);"></i> <span style="font-weight:600; color:var(--text-dark);"><%= producer.locality %></span>
                        </p>
                        <% if(producer.phone) { %>
                            <p style="color: gray; font-size: 0.95rem; margin-top:0.5rem; display:flex; align-items:center; gap:8px;">
                                <i class="fa-solid fa-phone" style="color:var(--primary);"></i> <%= producer.phone %>
                            </p>
                        <% } %>
                        <p style="margin-top: 1rem; color:#555; line-height:1.6; max-width:800px;">
                            <i><%= producer.history || "Somos productores directos. Aquí debajo encontrarás todos los productos que actualmente tenemos a la venta presencial de la huerta a tu casa." %></i>
                        </p>
                    </div>
                </div>

                <% if(avgRating && from !== 'admin') { %>
                <div style="display:flex; align-items:center; gap:8px; margin-top:0.5rem;">
                    <% for(let i=1; i<=5; i++) { %>
                        <i class="fa-solid fa-star" style="color:<%= i <= Math.round(parseFloat(avgRating)) ? '#f39c12' : '#ddd' %>; font-size:1rem;"></i>
                    <% } %>
                    <span style="font-weight:700; color:#f39c12;"><%= avgRating %></span>
                    <span style="color:gray; font-size:0.85rem;">(<%= reviews.length %> reseña<%= reviews.length !== 1 ? 's' : '' %>)</span>
                </div>
                <% } %>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
                    <h2><i class="fa-solid fa-boxes-stacked" style="color:var(--primary); margin-right:8px;"></i> Sus productos (<%= products.length %>)</h2>
                </div>
                <div class="products-grid">
                    <% products.forEach(function(p) { %>
                        <div class="produce-card">
                            <span class="card-badge"><%= p.category || 'Producto' %></span>
                            <span class="card-price"><%= p.price.toFixed(2) %>€</span>
                            <% if(from !== 'admin') { %>
                                <button id="fav-btn-<%= p.id %>" onclick="toggleFavorite(<%= p.id %>, this)" title="Guardar en favoritos"
                                    style="position:absolute; top:12px; right:60px; background:rgba(0,0,0,0.5); border:none; border-radius:50%; width:32px; height:32px; cursor:pointer; color:rgba(255,255,255,0.8); z-index:10; display:flex; align-items:center; justify-content:center; padding:0;">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            <% } %>
                            <img src="<%= p.image_url %>" alt="<%= p.name %>">
                            <div class="produce-info">
                                <h4><%= p.name %></h4>
                                <div class="pickup-tag"><i class="fa-solid fa-calendar-check"></i> Recogida: <%= p.pickup_day %></div>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <span style="font-weight:bold; font-size:1.1rem; color:var(--text-light);"><%= p.kg %>kg</span>
                                    <% if(from !== 'admin') { %>
                                        <button class="btn btn-primary" style="padding:0.5rem 1.2rem; font-weight:700;" onclick="addToCart(<%= p.id %>)"><i class="fa-solid fa-basket-shopping"></i> Comprar</button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    
                    <% if(products.length === 0) { %>
                        <p style="color:gray; grid-column:1/-1; text-align:center; padding:3rem;">Este productor no tiene productos activos ahora mismo.</p>
                    <% } %>
                </div>
            <% if(from !== 'admin' && reviews && reviews.length > 0) { %>
                <div style="margin-top:3rem;">
                    <h3 style="margin-bottom:1.5rem;"><i class="fa-solid fa-star" style="color:#f39c12;"></i> Reseñas de clientes</h3>
                    <% reviews.forEach(function(r) { %>
                        <div style="border:1px solid #eee; border-radius:12px; padding:1.2rem; margin-bottom:1rem;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.5rem;">
                                <div style="display:flex; align-items:center; gap:6px;">
                                    <div style="width:34px; height:34px; border-radius:50%; background:var(--primary); display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:0.9rem; flex-shrink:0;"><%= r.client_name ? r.client_name.charAt(0).toUpperCase() : '?' %></div>
                                    <span style="font-weight:700; font-size:0.95rem;"><%= r.client_name || 'Cliente' %></span>
                                </div>
                                <div>
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="fa-solid fa-star" style="color:<%= i <= r.rating ? '#f39c12' : '#ddd' %>; font-size:0.85rem;"></i>
                                    <% } %>
                                    <span style="font-size:0.78rem; color:gray; margin-left:4px;"><%= new Date(r.created_at).toLocaleDateString('es-ES') %></span>
                                </div>
                            </div>
                            <% if(r.comment) { %>
                                <p style="margin:0; font-size:0.9rem; color:#555; font-style:italic;">"<%= r.comment %>"</p>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            <% } %>

            <!-- Formulario de reseña (solo para clientes logueados) -->
            <% if(from !== 'admin' && producer) { %>
            <div id="reviewFormContainer" style="display:none; margin-top:2rem; background:#f9f9f9; border-radius:12px; padding:1.5rem;">
                <h4 style="margin-bottom:1rem;"><i class="fa-solid fa-pen" style="color:var(--primary);"></i> Deja tu valoración</h4>
                <div style="display:flex; gap:8px; margin-bottom:1rem;" id="starRating">
                    <% for(let i=1; i<=5; i++) { %>
                        <i class="fa-solid fa-star" data-val="<%= i %>" style="font-size:1.8rem; cursor:pointer; color:#ddd; transition:0.2s;"
                           onmouseover="highlightStars(<%= i %>)" onmouseout="resetStars()"
                           onclick="selectRating(<%= i %>)"></i>
                    <% } %>
                </div>
                <input type="hidden" id="selectedRating" value="0">
                <textarea id="reviewComment" placeholder="Comparte tu experiencia (opcional)..." style="width:100%; padding:0.8rem; border:1px solid #ddd; border-radius:8px; font-family:'Inter'; height:90px; resize:vertical; margin-bottom:0.8rem;"></textarea>
                <button class="btn btn-primary" onclick="submitReview(<%= producer.id %>)" style="padding:0.6rem 1.5rem;"><i class="fa-solid fa-paper-plane"></i> Publicar Reseña</button>
                <span id="reviewMsg" style="margin-left:1rem; font-size:0.85rem; display:none;"></span>
            </div>
            <% } %>

            <% } else { %>
                <h2>Productor no encontrado.</h2>
            <% } %>
        </div>
    </div>

    <% if(from !== 'admin') { %>
    <!-- Floating Cart Button -->
    <button class="floating-cart-btn" id="floatingCartBtn" onclick="toggleCart()" style="display:none;">
        <i class="fa-solid fa-basket-shopping"></i> Ver Cesta
        <span class="badge" id="floatingBadge">0</span>
    </button>

    <!-- Cart Sidebar -->
    <div class="cart-backdrop" onclick="toggleCart()"></div>
    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h2><i class="fa-solid fa-basket-shopping"></i> Tu Cesta</h2>
            <i class="fa-solid fa-xmark" style="font-size: 1.5rem; cursor:pointer;" onclick="toggleCart()"></i>
        </div>
        <div class="cart-body" id="cartItems">
            <p style="color: gray;">Tu cesta está vacía.</p>
        </div>
        <div class="cart-footer" id="cartFooter">
            <h3 style="display: flex; justify-content: space-between; margin-bottom: 1rem;">Total: <span id="cartTotal">0.00€</span></h3>
            <button class="btn btn-primary" style="width: 100%;" onclick="showCheckoutConfirm()">Tramitar Reserva</button>
        </div>
    </div>

    <!-- Confirmation Modal -->
    <div id="confirmModal" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:4000; display:none; justify-content:center; align-items:center; backdrop-filter:blur(3px);">
        <div style="background:white; padding:2rem; border-radius:16px; width:100%; max-width:460px; box-shadow:0 20px 60px rgba(0,0,0,0.2); max-height:90vh; overflow-y:auto;">
            <h2 style="margin-bottom:0.5rem;"><i class="fa-solid fa-clipboard-check" style="color:var(--primary);"></i> Confirmar Reserva</h2>
            <p style="color:gray; font-size:0.9rem; margin-bottom:1.5rem;">Revisa tu pedido antes de confirmar.</p>
            <div id="confirmItems"></div>
            <div style="background:#f0fff0; border-radius:10px; padding:1rem; margin-top:1rem;">
                <div style="display:flex; justify-content:space-between; font-size:1.1rem; font-weight:800; color:var(--primary);">
                    <span>Total</span><span id="confirmTotal"></span>
                </div>
            </div>
            <div style="display:flex; gap:0.75rem; margin-top:1.5rem;">
                <button class="btn btn-outline" style="flex:1;" onclick="closeConfirmModal()"><i class="fa-solid fa-arrow-left"></i> Volver</button>
                <button class="btn btn-primary" style="flex:2;" onclick="checkout()"><i class="fa-solid fa-paper-plane"></i> Confirmar y Tramitar</button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" style="position:fixed; bottom:-100px; left:50%; transform:translateX(-50%); background:#333; color:white; padding:12px 24px; border-radius:30px; font-weight:600; box-shadow:0 5px 15px rgba(0,0,0,0.2); transition:bottom 0.4s; z-index:9999;"></div>
    <% } %>

    <script>
        const productsData = <%- JSON.stringify(products) %>;
        const producerName = '<%= producer ? producer.name : "" %>';

        // Mostrar formulario de reseña solo si el usuario es cliente
        const userStr = localStorage.getItem('km0_user');
        if (userStr) {
            const user = JSON.parse(userStr);
            if (user.role === 'cliente') {
                const rf = document.getElementById('reviewFormContainer');
                if (rf) rf.style.display = 'block';
            }
        }

        // Stars rating
        let currentRating = 0;
        function highlightStars(val) {
            document.querySelectorAll('#starRating i').forEach((s, i) => {
                s.style.color = i < val ? '#f39c12' : '#ddd';
            });
        }
        function resetStars() { highlightStars(currentRating); }
        function selectRating(val) {
            currentRating = val;
            document.getElementById('selectedRating').value = val;
            highlightStars(val);
        }

        function submitReview(producerId) {
            const rating = parseInt(document.getElementById('selectedRating').value);
            const comment = document.getElementById('reviewComment').value.trim();
            const msgEl = document.getElementById('reviewMsg');
            if (!rating) { msgEl.innerText = 'Por favor selecciona una valoración.'; msgEl.style.color = 'red'; msgEl.style.display = 'inline'; return; }
            fetch('/api/reviews', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ producer_id: producerId, rating, comment })
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    msgEl.innerText = '¡Reseña publicada! Gracias por tu valoración.';
                    msgEl.style.color = 'var(--primary)';
                    msgEl.style.display = 'inline';
                    setTimeout(() => window.location.reload(), 1500);
                } else {
                    msgEl.innerText = data.message || 'No se pudo publicar la reseña.';
                    msgEl.style.color = 'red';
                    msgEl.style.display = 'inline';
                }
            });
        }

        <% if(from !== 'admin') { %>
        // === FAVORITOS ===
        let userFavorites = new Set();
        const _userStr = localStorage.getItem('km0_user');
        const currentUser = _userStr ? JSON.parse(_userStr) : null;

        if (currentUser && currentUser.role === 'cliente') {
            fetch('/api/favorites')
            .then(r => r.json())
            .then(data => {
                if (data.favorites) data.favorites.forEach(f => {
                    userFavorites.add(f.id);
                    const btn = document.getElementById('fav-btn-' + f.id);
                    if (btn) { btn.style.color = '#e74c3c'; btn.querySelector('i').className = 'fa-solid fa-heart'; }
                });
            }).catch(() => {});
        }

        function toggleFavorite(productId, btn) {
            if (!currentUser || currentUser.role !== 'cliente') { window.location.href = '/login'; return; }
            fetch('/api/favorites/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ product_id: productId })
            }).then(r => r.json()).then(data => {
                if (data.success) {
                    if (data.action === 'added') {
                        userFavorites.add(productId);
                        btn.style.color = '#e74c3c';
                        btn.querySelector('i').className = 'fa-solid fa-heart';
                    } else {
                        userFavorites.delete(productId);
                        btn.style.color = 'rgba(255,255,255,0.8)';
                        btn.querySelector('i').className = 'fa-regular fa-heart';
                    }
                }
            });
        }

        function showToast(msg, isError=false) {
            const t = document.getElementById('toast');
            t.innerText = msg;
            t.style.background = isError ? '#e74c3c' : '#2ecc71';
            t.style.bottom = '20px';
            setTimeout(() => t.style.bottom = '-100px', 3000);
        }

        let cart = JSON.parse(localStorage.getItem('km0_cart')) || [];
        const sidebar = document.getElementById('cartSidebar');
        const backdrop = document.querySelector('.cart-backdrop');

        function toggleCart() { sidebar.classList.toggle('open'); backdrop.classList.toggle('open'); }

        function addToCart(id) {
            const product = productsData.find(p => p.id === id);
            if (!product) return;
            product.producer_name = product.producer_name || producerName;
            const hasStock = product.stock !== null && product.stock !== undefined;
            if (hasStock && product.stock <= 0) return showToast(product.name + ' está agotado', true);
            const existing = cart.find(c => c.id === id);
            const currentQty = existing ? (existing.qty || 1) : 0;
            if (hasStock && currentQty + 1 > product.stock) {
                return showToast('Solo quedan ' + product.stock + ' unidad(es) de ' + product.name, true);
            }
            if (existing) {
                existing.qty = currentQty + 1;
            } else {
                cart.push({ ...product, qty: 1 });
            }
            localStorage.setItem('km0_cart', JSON.stringify(cart));
            updateCartUI();
            showToast('Producto añadido a la cesta');
        }

        function changeQty(id, delta) {
            const item = cart.find(c => c.id === id);
            if (!item) return;
            const product = productsData.find(p => p.id === id);
            const hasStock = product && product.stock !== null && product.stock !== undefined;
            const newQty = (item.qty || 1) + delta;
            if (delta > 0 && hasStock && newQty > product.stock) {
                return showToast('Solo quedan ' + product.stock + ' unidad(es) de ' + item.name, true);
            }
            item.qty = newQty;
            if (item.qty <= 0) cart = cart.filter(c => c.id !== id);
            localStorage.setItem('km0_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function updateCartUI() {
            const totalItems = cart.reduce((s, p) => s + (p.qty || 1), 0);
            [document.getElementById('cartCount'), document.getElementById('floatingBadge')].forEach(el => { if (el) el.innerText = totalItems; });
            document.getElementById('floatingCartBtn').style.display = cart.length > 0 ? 'flex' : 'none';

            const body = document.getElementById('cartItems');
            if (cart.length === 0) {
                body.innerHTML = '<p style="color:gray;">Tu cesta está vacía.</p>';
                document.getElementById('cartTotal').innerText = '0.00€';
                document.getElementById('cartFooter').style.display = '';
            } else {
                let html = '', total = 0;
                cart.forEach(p => {
                    const qty = p.qty || 1;
                    const lineTotal = p.price * qty;
                    total += lineTotal;
                    html += `<div class="cart-item">
                        <div style="flex:1;">
                            <h4 style="margin:0 0 2px;">${p.name}</h4>
                            <span style="font-size:0.8rem; color:gray;">${p.producer_name}</span>
                        </div>
                        <div style="display:flex; align-items:center; gap:6px;">
                            <button onclick="changeQty(${p.id},-1)" style="background:#eee; border:none; border-radius:4px; width:24px; height:24px; cursor:pointer; font-size:1rem; display:flex; align-items:center; justify-content:center;">−</button>
                            <span style="font-weight:700; min-width:16px; text-align:center;">${qty}</span>
                            <button onclick="changeQty(${p.id},1)" style="background:#eee; border:none; border-radius:4px; width:24px; height:24px; cursor:pointer; font-size:1rem; display:flex; align-items:center; justify-content:center;">+</button>
                        </div>
                        <div style="font-weight:bold; color:var(--primary); margin-left:10px; min-width:54px; text-align:right;">${lineTotal.toFixed(2)}€</div>
                    </div>`;
                });
                body.innerHTML = html;
                document.getElementById('cartTotal').innerText = total.toFixed(2) + '€';
            }
        }

        function showCheckoutConfirm() {
            if (cart.length === 0) return showToast('La cesta está vacía', true);
            const total = cart.reduce((s, p) => s + p.price * (p.qty || 1), 0);
            const itemsHtml = cart.map(p => {
                const qty = p.qty || 1;
                return `<div style="display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px dashed #eee; font-size:0.88rem;">
                    <span><b>${p.name}</b> <span style="color:gray;">× ${qty}</span></span>
                    <span style="font-weight:700; color:var(--primary);">${(p.price * qty).toFixed(2)}€</span>
                </div>`;
            }).join('');
            document.getElementById('confirmItems').innerHTML = itemsHtml;
            document.getElementById('confirmTotal').innerText = total.toFixed(2) + '€';
            document.getElementById('confirmModal').style.display = 'flex';
        }

        function closeConfirmModal() {
            document.getElementById('confirmModal').style.display = 'none';
        }

        function checkout() {
            closeConfirmModal();
            if (cart.length === 0) return showToast('La cesta está vacía', true);
            const u = localStorage.getItem('km0_user');
            if (u) {
                processOrder(JSON.parse(u).email);
            } else {
                document.getElementById('cartItems').innerHTML = `
                    <div style="padding:1rem 0;">
                        <h3 style="margin-bottom:1rem;">¿Cómo quieres continuar?</h3>
                        <a href="/login" class="btn btn-primary" style="width:100%; margin-bottom:0.8rem; display:block; text-align:center;"><i class="fa-solid fa-user"></i> Iniciar Sesión / Registrarme</a>
                        <div style="text-align:center; color:gray; margin:1rem 0; font-weight:600;">— o comprar como invitado —</div>
                        <div style="margin-bottom:0.8rem;"><label style="font-weight:600; display:block; margin-bottom:0.3rem;">Tu correo electrónico</label><input type="email" id="guestEmail" placeholder="tu@email.com" style="width:100%; padding:0.8rem; border:1px solid #ddd; border-radius:8px;"></div>
                        <div style="margin-bottom:1rem;"><label style="font-weight:600; display:block; margin-bottom:0.3rem;">Repite tu correo</label><input type="email" id="guestEmailConfirm" placeholder="tu@email.com" style="width:100%; padding:0.8rem; border:1px solid #ddd; border-radius:8px;"></div>
                        <small id="guestEmailError" style="color:red; display:none; margin-bottom:0.5rem;">Los correos no coinciden o el formato es inválido.</small>
                        <button class="btn btn-primary" style="width:100%;" onclick="submitGuestOrder()"><i class="fa-solid fa-paper-plane"></i> Confirmar como Invitado</button>
                        <button class="btn btn-outline" style="width:100%; margin-top:0.5rem;" onclick="updateCartUI()"><i class="fa-solid fa-arrow-left"></i> Volver a la cesta</button>
                    </div>`;
                document.getElementById('cartFooter').style.display = 'none';
            }
        }

        function submitGuestOrder() {
            const email = document.getElementById('guestEmail').value;
            const emailConfirm = document.getElementById('guestEmailConfirm').value;
            if (!email || email !== emailConfirm || !/^[^@]+@[^@]+\.[a-zA-Z]{2,}$/.test(email)) {
                document.getElementById('guestEmailError').style.display = 'block';
                return;
            }
            processOrder(email);
        }

        function processOrder(client_email) {
            fetch('/api/orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: cart, client_email })
            }).then(r => r.json()).then(data => {
                if (!data.success) {
                    showToast(data.message || 'No se pudo tramitar el pedido', true);
                    if (data.product_id) {
                        const prod = productsData.find(p => p.id === data.product_id);
                        if (prod && data.available !== undefined) prod.stock = data.available;
                        updateCartUI();
                    }
                    return;
                }
                const qrPayload = data.qr_payload;
                const total = cart.reduce((s, p) => s + p.price * (p.qty || 1), 0);
                const itemsHtml = cart.map(p => {
                    const qty = p.qty || 1;
                    return `<div style="display:flex; justify-content:space-between; padding:0.4rem 0; border-bottom:1px dashed #eee; font-size:0.85rem;">
                        <span><b>${p.name}</b> × ${qty} <span style="color:gray;">· ${p.producer_name}</span></span>
                        <span style="font-weight:700; color:var(--primary);">${(p.price * qty).toFixed(2)}€</span>
                    </div>`;
                }).join('');

                const emailNote = data.emailPreviewUrl
                    ? `<div style="background:#fff3cd; padding:12px; border-radius:8px; margin-top:1rem; border:1px solid #ffc107;">
                        <p style="margin:0; font-size:0.85rem; color:#856404;"><i class="fa-solid fa-flask"></i> <b>Modo de pruebas:</b> <a href="${data.emailPreviewUrl}" target="_blank" style="color:#856404; font-weight:700;">Ver email de confirmación</a></p>
                       </div>`
                    : `<p style="margin-top:1rem; font-size:0.85rem; color:gray;"><i class="fa-solid fa-check-circle" style="color:var(--primary);"></i> Email enviado a <b>${client_email}</b></p>`;

                document.getElementById('cartItems').innerHTML = `
                    <div style="padding:1.5rem 0;">
                        <div style="text-align:center; margin-bottom:1.5rem;">
                            <i class="fa-solid fa-circle-check" style="font-size:3rem; color:var(--primary); margin-bottom:0.5rem;"></i>
                            <h2 style="margin:0.3rem 0;">¡Reserva Confirmada!</h2>
                        </div>
                        <div style="display:flex; justify-content:center; margin:1rem 0;"><div id="qrcode-container" style="padding:12px; background:white; border-radius:12px; box-shadow:0 5px 15px rgba(0,0,0,0.05); display:inline-block;"></div></div>
                        <div style="background:#f9f9f9; border-radius:10px; padding:1rem; font-size:0.85rem; margin-bottom:1rem;">
                            <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
                                <span style="color:gray;"><i class="fa-solid fa-hashtag"></i> Referencia</span>
                                <span style="font-weight:700; font-family:monospace;">${data.qr_code}</span>
                            </div>
                            <div style="display:flex; justify-content:space-between; margin-bottom:0.8rem;">
                                <span style="color:gray;"><i class="fa-solid fa-user"></i> Cliente</span>
                                <span style="font-weight:600;">${client_email}</span>
                            </div>
                            <div style="border-top:1px solid #eee; padding-top:0.8rem;">
                                <p style="margin:0 0 0.5rem; font-weight:600; color:#333;"><i class="fa-solid fa-boxes-stacked" style="color:var(--primary);"></i> Artículos</p>
                                ${itemsHtml}
                                <div style="display:flex; justify-content:space-between; padding-top:0.6rem; font-size:0.95rem;">
                                    <span style="font-weight:700;">Total</span>
                                    <span style="font-weight:800; color:var(--primary);">${total.toFixed(2)}€</span>
                                </div>
                            </div>
                        </div>
                        ${emailNote}
                    </div>`;
                document.getElementById('cartFooter').style.display = 'none';
                document.getElementById('floatingCartBtn').style.display = 'none';
                cart = [];
                localStorage.removeItem('km0_cart');
                if (qrPayload) {
                    setTimeout(() => {
                        const qrEl = document.getElementById('qrcode-container');
                        if (qrEl) new QRCode(qrEl, { text: qrPayload, width: 160, height: 160, colorDark: '#1a7a3a', colorLight: '#ffffff', correctLevel: QRCode.CorrectLevel.M });
                    }, 50);
                }
            });
        }

        updateCartUI();
        <% } %>
    </script>
    <%- include('partials/footer') %>
</body>
</html>
