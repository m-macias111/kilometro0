<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | <%= producer ? producer.name : 'Productor' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <style>
        body { background: #f4f6f8; overflow: hidden; }
        .dashboard { display: grid; grid-template-columns: 250px 1fr; height: 100vh; }
        
        .side-nav { background: linear-gradient(180deg, #1a7a3a 0%, #145a2b 100%); padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
        .side-nav .logo { margin-bottom: 2rem; color: white; }
        .side-nav .logo i { color: #8fff8f; }
        .side-nav .logo span { color: white; }
        .nav-item { padding: 1rem; border-radius: 12px; cursor: pointer; font-weight: 600; color: rgba(255,255,255,0.8); display: flex; align-items: center; gap: 12px; transition: 0.3s; }
        .nav-item:hover { background: rgba(255,255,255,0.2); color: white; }
        
        .main-content { padding: 2rem; overflow-y: auto; position: relative; }
        
        .producer-hero { background: white; border-radius: 16px; padding: 3rem; margin-bottom: 2rem; display: flex; gap: 2rem; align-items: center; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
        .producer-hero::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(90deg, #1a7a3a, #8bc34a); }
        .producer-avatar { width: 120px; height: 120px; background: var(--primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: bold; flex-shrink: 0; }
        
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
        .produce-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid #f0f0f0; transition: 0.3s; position: relative; }
        .produce-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: var(--primary); }
        .produce-card img { width: 100%; height: 200px; object-fit: cover; }
        .produce-card .card-badge { position:absolute; top:12px; left:12px; background:var(--primary); color:white; padding:4px 10px; border-radius:20px; font-size:0.75rem; font-weight:700; }
        .produce-card .card-price { position:absolute; top:12px; right:12px; background:rgba(0,0,0,0.7); color:white; padding:6px 12px; border-radius:20px; font-size:1rem; font-weight:800; }
        .produce-info { padding: 1.2rem 1.5rem; }
        .produce-info h4 { margin-bottom: 0.3rem; }
        .pickup-tag { display:inline-flex; align-items:center; gap:4px; font-size:0.78rem; color:#555; background:#f0f7f0; padding:3px 8px; border-radius:6px; margin-bottom:0.8rem; }

        .cart-sidebar { position: fixed; right: -400px; top: 0; width: 400px; height: 100vh; background: white; box-shadow: -5px 0 30px rgba(0,0,0,0.1); z-index: 3000; transition: right 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; flex-direction: column; }
        .cart-sidebar.open { right: 0; }
        .cart-header { padding: 2rem; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        .cart-body { flex: 1; padding: 2rem; overflow-y: auto; }
        .cart-footer { padding: 2rem; border-top: 1px solid #eee; background: #f9f9f9; }
        .cart-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; border-bottom: 1px dashed #eee; padding-bottom: 1rem; }
        .cart-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 2999; display: none; backdrop-filter: blur(3px); }
        .cart-backdrop.open { display: block; }

        .floating-cart-btn { position: fixed; bottom: 2rem; right: 2rem; background: #1a7a3a; color: white; border: none; padding: 1rem 1.5rem; border-radius: 50px; font-size: 1rem; font-weight: 700; cursor: pointer; box-shadow: 0 8px 25px rgba(0,0,0,0.2); z-index: 2000; display: flex; align-items: center; gap: 10px; transition: 0.3s; font-family: 'Inter'; }
        .floating-cart-btn:hover { transform: translateY(-3px); box-shadow: 0 12px 35px rgba(0,0,0,0.25); }
        .floating-cart-btn .badge { background: #ff6b35; color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="side-nav">
            <div class="logo">
                <i class="fa-solid fa-leaf"></i>
                <span>Kilómetro 0</span>
            </div>
            <div class="nav-item" onclick="window.location.href='/'">
                <i class="fa-solid fa-arrow-left"></i> Volver a Tienda
            </div>
            <div class="nav-item" onclick="toggleCart()">
                <i class="fa-solid fa-basket-shopping"></i> Ver Cesta (<span id="cartCount">0</span>)
            </div>
        </div>

        <div class="main-content">
            <% if(producer) { %>
                <div class="producer-hero">
                    <% if(producer.profileImage) { %>
                        <img src="<%= producer.profileImage %>" class="producer-avatar" style="object-fit:cover;">
                    <% } else { %>
                        <div class="producer-avatar"><i class="fa-solid fa-tractor"></i></div>
                    <% } %>
                    <div>
                        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= producer.name %> <%= producer.lastName || '' %></h1>
                        <p style="color: gray; font-size: 1.1rem; display:flex; align-items:center; gap:8px;">
                            <i class="fa-solid fa-location-dot" style="color:var(--primary);"></i> <span style="font-weight:600; color:var(--text-dark);"><%= producer.locality %></span>
                        </p>
                        <% if(producer.phone) { %>
                            <p style="color: gray; font-size: 0.95rem; margin-top:0.5rem; display:flex; align-items:center; gap:8px;">
                                <i class="fa-solid fa-phone" style="color:var(--primary);"></i> <%= producer.phone %>
                            </p>
                        <% } %>
                        <p style="margin-top: 1rem; color:#555; line-height:1.6; max-width:800px;">
                            <i><%= producer.history || "Somos productores directos. Aquí debajo encontrarás todos los productos que actualmente tenemos a la venta presencial de la huerta a tu casa." %></i>
                        </p>
                    </div>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
                    <h2><i class="fa-solid fa-boxes-stacked" style="color:var(--primary); margin-right:8px;"></i> Sus productos (<%= products.length %>)</h2>
                </div>
                <div class="products-grid">
                    <% products.forEach(function(p) { %>
                        <div class="produce-card">
                            <span class="card-badge"><%= p.category || 'Producto' %></span>
                            <span class="card-price"><%= p.price.toFixed(2) %>€</span>
                            <img src="<%= p.image_url %>" alt="<%= p.name %>">
                            <div class="produce-info">
                                <h4><%= p.name %></h4>
                                <div class="pickup-tag"><i class="fa-solid fa-calendar-check"></i> Recogida: <%= p.pickup_day %></div>
                                <div style="display:flex; justify-content:space-between; align-items:center;">
                                    <span style="font-weight:bold; font-size:1.1rem; color:var(--text-light);"><%= p.kg %>kg</span>
                                    <button class="btn btn-primary" style="padding:0.5rem 1.2rem; font-weight:700;" onclick="addToCart(<%= p.id %>)"><i class="fa-solid fa-basket-shopping"></i> Comprar</button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    
                    <% if(products.length === 0) { %>
                        <p style="color:gray; grid-column:1/-1; text-align:center; padding:3rem;">Este productor no tiene productos activos ahora mismo.</p>
                    <% } %>
                </div>
            <% } else { %>
                <h2>Productor no encontrado.</h2>
            <% } %>
        </div>
    </div>

    <!-- Floating Cart Button -->
    <button class="floating-cart-btn" id="floatingCartBtn" onclick="toggleCart()" style="display:none;">
        <i class="fa-solid fa-basket-shopping"></i> Ver Cesta
        <span class="badge" id="floatingBadge">0</span>
    </button>

    <!-- Cart Sidebar -->
    <div class="cart-backdrop" onclick="toggleCart()"></div>
    <div class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
            <h2><i class="fa-solid fa-basket-shopping"></i> Tu Cesta</h2>
            <i class="fa-solid fa-xmark" style="font-size: 1.5rem; cursor:pointer;" onclick="toggleCart()"></i>
        </div>
        <div class="cart-body" id="cartItems">
            <p style="color: gray;">Tu cesta está vacía.</p>
        </div>
        <div class="cart-footer" id="cartFooter">
            <h3 style="display: flex; justify-content: space-between; margin-bottom: 1rem;">Total: <span id="cartTotal">0.00€</span></h3>
            <button class="btn btn-primary" style="width: 100%;" onclick="checkout()">Tramitar Reserva</button>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" style="position:fixed; bottom:-100px; left:50%; transform:translateX(-50%); background:#333; color:white; padding:12px 24px; border-radius:30px; font-weight:600; box-shadow:0 5px 15px rgba(0,0,0,0.2); transition:bottom 0.4s; z-index:9999;"></div>

    <script>
        const productsData = <%- JSON.stringify(products) %>;
        const producerName = '<%= producer ? producer.name : "" %>';

        function showToast(msg, isError=false) {
            const t = document.getElementById('toast');
            t.innerText = msg;
            t.style.background = isError ? '#e74c3c' : '#2ecc71';
            t.style.bottom = '20px';
            setTimeout(() => t.style.bottom = '-100px', 3000);
        }

        let cart = JSON.parse(localStorage.getItem('km0_cart')) || [];
        const sidebar = document.getElementById('cartSidebar');
        const backdrop = document.querySelector('.cart-backdrop');

        function toggleCart() { sidebar.classList.toggle('open'); backdrop.classList.toggle('open'); }

        function addToCart(id) {
            const product = productsData.find(p => p.id === id);
            if(!product) return;
            // Enrich with producer_name for cart display
            product.producer_name = product.producer_name || producerName;
            cart.push(product);
            localStorage.setItem('km0_cart', JSON.stringify(cart));
            updateCartUI();
            showToast('Producto añadido a la cesta');
        }

        function updateCartUI() {
            const counts = [document.getElementById('cartCount'), document.getElementById('floatingBadge')];
            counts.forEach(el => { if(el) el.innerText = cart.length; });
            // Show/hide floating button
            document.getElementById('floatingCartBtn').style.display = cart.length > 0 ? 'flex' : 'none';

            const body = document.getElementById('cartItems');
            if(cart.length === 0) {
                body.innerHTML = '<p style="color:gray;">Tu cesta está vacía.</p>';
                document.getElementById('cartFooter').style.display = '';
            } else {
                let html = '', total = 0;
                cart.forEach(p => {
                    total += p.price;
                    html += `<div class="cart-item"><div><h4 style="margin:0;">${p.name}</h4><span style="font-size:0.8rem; color:gray;">${p.producer_name}</span></div><div style="font-weight:bold; color:var(--primary);">${p.price.toFixed(2)}€</div></div>`;
                });
                body.innerHTML = html;
                document.getElementById('cartTotal').innerText = total.toFixed(2) + '€';
            }
        }

        function checkout() {
            if(cart.length === 0) return showToast('La cesta está vacía', true);
            const u = localStorage.getItem('km0_user');
            if(u) {
                processOrder(JSON.parse(u).email);
            } else {
                document.getElementById('cartItems').innerHTML = `
                    <div style="padding:1rem 0;">
                        <h3 style="margin-bottom:1rem;">¿Cómo quieres continuar?</h3>
                        <a href="/login" class="btn btn-primary" style="width:100%; margin-bottom:0.8rem; display:block; text-align:center;"><i class="fa-solid fa-user"></i> Iniciar Sesión / Registrarme</a>
                        <div style="text-align:center; color:gray; margin:1rem 0; font-weight:600;">— o comprar como invitado —</div>
                        <div style="margin-bottom:0.8rem;"><label style="font-weight:600; display:block; margin-bottom:0.3rem;">Tu correo electrónico</label><input type="email" id="guestEmail" placeholder="tu@email.com" style="width:100%; padding:0.8rem; border:1px solid #ddd; border-radius:8px;"></div>
                        <div style="margin-bottom:1rem;"><label style="font-weight:600; display:block; margin-bottom:0.3rem;">Repite tu correo</label><input type="email" id="guestEmailConfirm" placeholder="tu@email.com" style="width:100%; padding:0.8rem; border:1px solid #ddd; border-radius:8px;"></div>
                        <small id="guestEmailError" style="color:red; display:none; margin-bottom:0.5rem;">Los correos no coinciden o el formato es inválido.</small>
                        <button class="btn btn-primary" style="width:100%;" onclick="submitGuestOrder()"><i class="fa-solid fa-paper-plane"></i> Confirmar como Invitado</button>
                        <button class="btn btn-outline" style="width:100%; margin-top:0.5rem;" onclick="updateCartUI()"><i class="fa-solid fa-arrow-left"></i> Volver a la cesta</button>
                    </div>`;
                document.getElementById('cartFooter').style.display = 'none';
            }
        }

        function submitGuestOrder() {
            const email = document.getElementById('guestEmail').value;
            const emailConfirm = document.getElementById('guestEmailConfirm').value;
            if(!email || email !== emailConfirm || !/^[^@]+@[^@]+\.[a-zA-Z]{2,}$/.test(email)) {
                document.getElementById('guestEmailError').style.display = 'block';
                return;
            }
            processOrder(email);
        }

        function processOrder(client_email) {
            fetch('/api/orders', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: cart, client_email })
            }).then(r => r.json()).then(data => {
                const pickupInfo = [...new Set(cart.map(p => `<li><b>${p.producer_name}</b></li>`))].join('');
                const emailNote = data.emailPreviewUrl 
                    ? `<div style="background:#fff3cd; padding:12px; border-radius:8px; margin-top:1rem; border:1px solid #ffc107;">
                        <p style="margin:0; font-size:0.85rem; color:#856404;"><i class="fa-solid fa-flask"></i> <b>Modo de pruebas:</b> El correo no llega a tu buzón real. Puedes verlo aquí:</p>
                        <a href="${data.emailPreviewUrl}" target="_blank" style="display:block; text-align:center; margin-top:8px; background:#1a7a3a; color:white; padding:10px; border-radius:8px; text-decoration:none; font-weight:700;"><i class="fa-solid fa-envelope-open-text"></i> Ver Email de Confirmación</a>
                       </div>`
                    : `<p style="margin-top:1rem; font-size:0.85rem; color:gray;"><i class="fa-solid fa-check-circle" style="color:var(--primary);"></i> Email enviado correctamente a <b>${client_email}</b></p>`;
                document.getElementById('cartItems').innerHTML = `
                    <div style="text-align:center; padding:2rem 0;">
                        <i class="fa-solid fa-circle-check" style="font-size:4rem; color:var(--primary); margin-bottom:1rem;"></i>
                        <h2>¡Reserva Confirmada!</h2>
                        <p style="color:gray; font-size:0.9rem;">Correo de confirmación para <b>${client_email}</b></p>
                        <div id="qrcode-container" style="display:flex; justify-content:center; margin:1.5rem 0; padding:10px; background:white; border-radius:12px; box-shadow:0 5px 15px rgba(0,0,0,0.05);"></div>
                        <p style="color:gray; font-size:0.9rem;">Referencia: ${data.qr_code}</p>
                        <div style="text-align:left; background:#f9f9f9; padding:1rem; border-radius:8px; margin-top:1rem;">
                            <h4 style="margin:0 0 0.5rem;"><i class="fa-solid fa-location-dot" style="color:var(--primary);"></i> Punto de recogida:</h4>
                            <ul style="margin:0; padding-left:1.2rem; font-size:0.9rem; color:#555;">${pickupInfo}</ul>
                        </div>
                        ${emailNote}
                    </div>`;
                new QRCode(document.getElementById("qrcode-container"), { text: data.qr_code, width: 180, height: 180, colorDark: "#27ae60", colorLight: "#ffffff", correctLevel: QRCode.CorrectLevel.M });
                document.getElementById('cartFooter').style.display = 'none';
                document.getElementById('floatingCartBtn').style.display = 'none';
                cart = [];
                localStorage.removeItem('km0_cart');
                document.getElementById('cartCount').innerText = '0';
            });
        }
        
        // Initial setup
        updateCartUI();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
