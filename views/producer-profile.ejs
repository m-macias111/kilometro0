<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Perfil de Productor</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #f4f6f8; overflow: hidden; }
        .dashboard { display: grid; grid-template-columns: 250px 1fr; height: 100vh; }
        
        .side-nav { background: white; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 1rem; border-right: 1px solid #eee; }
        .side-nav .logo { margin-bottom: 2rem; }
        .nav-item { padding: 1rem; border-radius: 12px; cursor: pointer; font-weight: 600; color: var(--secondary); display: flex; align-items: center; gap: 12px; transition: 0.3s; }
        .nav-item:hover, .nav-item.active { background: var(--primary); color: white; }
        
        .main-content { padding: 2rem; overflow-y: auto; position: relative; }
        
        .producer-hero { background: white; border-radius: 16px; padding: 3rem; margin-bottom: 2rem; display: flex; gap: 2rem; align-items: center; box-shadow: var(--shadow-sm); position: relative; overflow: hidden; }
        .producer-hero::before { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 8px; background: linear-gradient(90deg, var(--primary), #8bc34a); }
        .producer-avatar { width: 120px; height: 120px; background: var(--primary); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3rem; font-weight: bold; }
        
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
        .produce-card { background: white; border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-sm); border: 1px solid #f0f0f0;}
        .produce-card img { width: 100%; height: 200px; object-fit: cover; }
        .produce-info { padding: 1.5rem; }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="side-nav">
            <div class="logo">
                <i class="fa-solid fa-leaf"></i>
                <span>Kilómetro 0</span>
            </div>
            <div class="nav-item" onclick="window.location.href='/'">
                <i class="fa-solid fa-arrow-left"></i> Volver a Tienda
            </div>
        </div>

        <div class="main-content">
            <% if(producer) { %>
                <div class="producer-hero">
                    <div class="producer-avatar"><i class="fa-solid fa-tractor"></i></div>
                    <div>
                        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;"><%= producer.name %></h1>
                        <p style="color: gray; font-size: 1.1rem; display:flex; align-items:center; gap:8px;">
                            <i class="fa-solid fa-location-dot" style="color:var(--primary);"></i> Punto de Recogida: <span style="font-weight:600; color:var(--text-dark);">Longitud <%= producer.lng %>, Latitud <%= producer.lat %></span>
                        </p>
                        <p style="margin-top: 1rem;">Somos productores directos. Aquí debajo encontrarás todos los productos que actualmente tenemos a la venta presencial de la huerta a tu casa.</p>
                    </div>
                </div>

                <h2 style="margin-bottom: 1.5rem;">Todos sus productos</h2>
                <div class="products-grid">
                    <% products.forEach(function(p) { %>
                        <div class="produce-card">
                            <img src="<%= p.image_url %>" alt="<%= p.name %>">
                            <div class="produce-info">
                                <h4><%= p.name %></h4>
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-top:10px;">
                                    <span style="font-weight:bold; font-size:1.2rem; color:var(--primary);"><%= p.price.toFixed(2) %>€</span>
                                    <button class="btn btn-outline" style="padding: 0.4rem 0.8rem;" onclick="window.location.href='/'">Ver en tienda</button>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                    
                    <% if(products.length === 0) { %>
                        <p>Este productor no tiene productos activos ahora mismo.</p>
                    <% } %>
                </div>
            <% } else { %>
                <h2>Productor no encontrado.</h2>
            <% } %>
        </div>
    </div>
</body>
</html>
