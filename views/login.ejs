<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Iniciar Sesión</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: var(--bg-color); }
        .auth-container { background: white; padding: 3rem; border-radius: 16px; box-shadow: var(--shadow-md); width: 100%; max-width: 450px; text-align: center; }
        .logo { justify-content: center; margin-bottom: 2rem; font-size: 2rem; display: flex; align-items:center; gap:8px;}
        .form-group { text-align: left; margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
        .form-group input { width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px; outline: none; }
        .form-group input:focus { border-color: var(--primary); }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo">
            <i class="fa-solid fa-leaf" style="color:var(--primary);"></i>
            <span style="font-family:'Outfit'; font-weight:800; color:var(--primary);">Kilómetro 0</span>
        </div>
        <h2 style="margin-bottom: 0.5rem;">¡Estábamos esperándote!</h2>
        <p style="color: var(--text-light); margin-bottom: 2rem;">Inicia sesión para continuar</p>
        
        <form id="loginForm" onsubmit="handleLogin(event)">
            <div class="form-group">
                <label>Correo Electrónico</label>
                <input type="email" id="email" required placeholder="tu@email.com">
            </div>
            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" id="password" required placeholder="••••••••">
            </div>
            
            <button class="btn btn-primary" type="submit" style="width: 100%; margin-top: 1rem;">Entrar</button>
        </form>
        
        <p style="margin-top: 2rem; color: var(--text-light);">
            ¿No tienes cuenta? <a href="/register" style="color: var(--primary); font-weight: bold;">Regístrate</a>
        </p>
        <p style="margin-top: 1rem;">
            <a href="/" style="font-size:0.9rem; color:gray;"><i class="fa-solid fa-arrow-left"></i> Volver a inicio</a>
        </p>
    </div>

    <script>
        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            if(email === 'admin@admin' && password === 'admin') {
                localStorage.setItem('km0_user', JSON.stringify({ email: email, name: 'Súper Administrador', role: 'admin' }));
                window.location.href = '/admin-app';
                return;
            }

            localStorage.setItem('km0_user', JSON.stringify({ email: email, name: email.split('@')[0], role: email.includes('productor') ? 'productor' : 'cliente' }));
            
            if(email.includes('productor')) window.location.href = '/producer-app';
            else window.location.href = '/';
        }
    </script>
</body>
</html>
