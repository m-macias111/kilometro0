<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>Kilómetro 0 | Nueva Contraseña</title>
    <style>
        body { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: var(--bg-color); }
        .auth-container { background: white; padding: 3rem; border-radius: 16px; box-shadow: var(--shadow-md); width: 100%; max-width: 450px; text-align: center; }
        .logo { justify-content: center; margin-bottom: 2rem; font-size: 2rem; display: flex; align-items:center; gap:8px; }
        .form-group { text-align: left; margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
        .form-group input { width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 8px; outline: none; font-family: inherit; }
        .form-group input:focus { border-color: var(--primary); }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="logo">
            <i class="fa-solid fa-leaf" style="color:var(--primary);"></i>
            <span style="font-family:'Outfit'; font-weight:800; color:var(--primary);">Kilómetro 0</span>
        </div>

        <div id="loadingSection">
            <i class="fa-solid fa-spinner fa-spin" style="font-size:3rem; color:var(--primary); margin-bottom:1rem;"></i>
            <p>Verificando enlace...</p>
        </div>

        <div id="invalidSection" style="display:none;">
            <i class="fa-solid fa-circle-xmark" style="font-size:4rem; color:#e74c3c; margin-bottom:1rem;"></i>
            <h2 style="margin-bottom:0.5rem;">Enlace inválido o expirado</h2>
            <p style="color:var(--text-light); margin-bottom:1.5rem;">Este enlace de recuperación no es válido o ya ha expirado. Solicita uno nuevo.</p>
            <a href="/forgot-password" class="btn btn-primary" style="display:block;">Solicitar nuevo enlace</a>
        </div>

        <div id="formSection" style="display:none;">
            <i class="fa-solid fa-key" style="font-size:3rem; color:var(--primary); margin-bottom:1rem;"></i>
            <h2 style="margin-bottom:0.5rem;">Nueva contraseña</h2>
            <p style="color:var(--text-light); margin-bottom:2rem;">Elige una contraseña segura de al menos 6 caracteres.</p>
            <form id="resetForm" onsubmit="handleReset(event)">
                <div class="form-group">
                    <label>Nueva contraseña</label>
                    <input type="password" id="password" required placeholder="Mínimo 6 caracteres" minlength="6">
                </div>
                <div class="form-group">
                    <label>Repite la contraseña</label>
                    <input type="password" id="password2" required placeholder="••••••••">
                </div>
                <button class="btn btn-primary" type="submit" id="submitBtn" style="width:100%; margin-top:0.5rem;">
                    <i class="fa-solid fa-floppy-disk"></i> Guardar nueva contraseña
                </button>
                <p id="errMsg" style="color:red; margin-top:1rem; font-weight:600; display:none;"></p>
            </form>
        </div>

        <div id="successSection" style="display:none;">
            <i class="fa-solid fa-circle-check" style="font-size:4rem; color:var(--primary); margin-bottom:1rem;"></i>
            <h2 style="margin-bottom:0.5rem;">¡Contraseña cambiada!</h2>
            <p style="color:var(--text-light); margin-bottom:1.5rem;">Tu contraseña ha sido restablecida correctamente. Ya puedes iniciar sesión.</p>
            <a href="/login" class="btn btn-primary" style="display:block;">Iniciar sesión</a>
        </div>
    </div>

    <script>
        const TOKEN = '<%= token %>';

        function show(id) {
            ['loadingSection','invalidSection','formSection','successSection'].forEach(s => {
                document.getElementById(s).style.display = s === id ? 'block' : 'none';
            });
        }

        // Validar token al cargar
        fetch('/api/auth/validate-reset-token?token=' + encodeURIComponent(TOKEN))
        .then(r => r.json())
        .then(data => {
            if (data.valid) show('formSection');
            else show('invalidSection');
        })
        .catch(() => show('invalidSection'));

        function handleReset(e) {
            e.preventDefault();
            const password = document.getElementById('password').value;
            const password2 = document.getElementById('password2').value;
            const errMsg = document.getElementById('errMsg');
            errMsg.style.display = 'none';

            if (password !== password2) {
                errMsg.innerText = 'Las contraseñas no coinciden.';
                errMsg.style.display = 'block';
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Guardando...';

            fetch('/api/auth/reset-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: TOKEN, password })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    show('successSection');
                } else {
                    errMsg.innerText = data.message || 'Error al cambiar la contraseña.';
                    errMsg.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar nueva contraseña';
                }
            })
            .catch(() => {
                errMsg.innerText = 'Error de conexión con el servidor.';
                errMsg.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Guardar nueva contraseña';
            });
        }
    </script>
    <%- include('partials/footer') %>
</body>
</html>
