<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Panel de Productor</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f0f2f5; }
        .dashboard-container { max-width: 1000px; margin: 3rem auto; display: grid; grid-template-columns: 300px 1fr; gap: 2rem; padding: 0 1rem; }
        .menu-bar { background: white; padding: 2rem; border-radius: 16px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem; }
        .menu-item { padding: 1rem; border-radius: 8px; cursor: pointer; transition: 0.3s; font-weight: 600; color: var(--secondary); display: flex; align-items: center; gap: 10px; }
        .menu-item:hover, .menu-item.active { background: var(--primary); color: white; }
        
        .content-area { background: white; padding: 2rem; border-radius: 16px; box-shadow: var(--shadow-sm); min-height: 500px; }
        .content-panel { display: none; }
        .content-panel.active { display: block; animation: fadeIn 0.4s ease; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .form-group { margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
        .form-group input { width: 100%; padding: 0.8rem; border: 1px solid #ccc; border-radius: 8px; font-family: 'Inter'; }
        
        .qr-scanner-box { border: 2px dashed var(--primary); padding: 3rem; text-align: center; border-radius: 12px; margin-top: 2rem; cursor: pointer; transition: 0.3s; background: rgba(46,204,113,0.05); }
        .qr-scanner-box:hover { background: rgba(46,204,113,0.1); }
        
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: rgba(46,204,113,0.05); border: 1px solid rgba(46,204,113,0.2); padding: 1.5rem; border-radius: 12px; text-align: center; }
        .stat-card h3 { font-size: 2rem; color: var(--primary); margin-bottom: 0.5rem; }
        .stat-card p { margin: 0; color: var(--text-light); font-weight: 600; font-size: 0.9rem; }
    </style>
</head>
<body>
    <nav class="navbar" style="position:static; background:white;">
        <div class="logo">
            <i class="fa-solid fa-tractor"></i>
            <span>Portal Productor</span>
        </div>
        <div class="nav-links">
            <span id="userName" style="font-weight:600; margin-right:1rem;"></span>
            <button onclick="logoutProducer()" class="btn btn-outline">Cerrar Sesión</button>
        </div>
    </nav>

    <div class="dashboard-container">
        <div class="menu-bar">
            <div class="menu-item active" onclick="switchTab('tab-products')"><i class="fa-solid fa-boxes-stacked"></i> Mis Packs</div>
            <div class="menu-item" onclick="switchTab('tab-location')"><i class="fa-solid fa-location-dot"></i> Punto de Venta</div>
            <div class="menu-item" onclick="switchTab('tab-scan')"><i class="fa-solid fa-qrcode"></i> Escanear Recogida</div>
            <div class="menu-item" onclick="window.location.href='/'" style="margin-top:2rem;"><i class="fa-solid fa-arrow-left"></i> Volver a Tienda</div>
        </div>

        <div class="content-area">
            <div id="tab-products" class="content-panel active">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #eee; padding-bottom:1rem; margin-bottom:1.5rem;">
                    <h2>Mis Packs de Productos</h2>
                    <button class="btn btn-primary" onclick="alert('Añadir producto demo')">+ Crear Pack</button>
                </div>
                
                <div class="stats-grid">
                    <div class="stat-card"><h3>14</h3><p>Ventas Mes</p></div>
                    <div class="stat-card"><h3>215€</h3><p>Ingresos</p></div>
                    <div class="stat-card"><h3>3</h3><p>Pendientes</p></div>
                </div>

                <div class="product-card" style="box-shadow: none; border: 1px solid #ddd; flex-direction: row; align-items: center; background: white; border-radius: 12px; padding: 1rem; display: flex; gap: 1rem;">
                    <img src="https://images.unsplash.com/photo-1592924357228-91a4daadcfea?w=200" style="width:80px; height:80px; border-radius:8px; object-fit:cover;" alt="">
                    <div style="flex:1;">
                        <h4 style="margin:0;">Pack Tomates Rosa 5kg</h4>
                        <p style="margin:0;color:gray;">Punto: Madrid</p>
                    </div>
                    <div style="font-weight:bold; color:var(--primary); font-size: 1.2rem;">12.50€</div>
                </div>
            </div>

            <div id="tab-location" class="content-panel">
                <h2>Punto de Venta</h2>
                <div class="form-group mt-3"><label>Nombre</label><input type="text" value="Granja Principal"></div>
                <div class="form-group"><label>Día de Recogida</label><input type="text" value="Viernes por la mañana"></div>
                <button class="btn btn-secondary">Guardar</button>
            </div>

            <div id="tab-scan" class="content-panel">
                <h2>Verificar Recogida</h2>
                <p>Escanea el código QR que el cliente proporciona para procesar la entrega.</p>
                <div class="qr-scanner-box" onclick="simulateScan()">
                    <i class="fa-solid fa-camera" style="font-size: 4rem; color: var(--primary); margin-bottom: 1rem;"></i>
                    <h3 id="scanText">Haz clic para Simular Escaneo</h3>
                </div>
            </div>
        </div>
    </div>

    <script>
        const userStr = localStorage.getItem('km0_user');
        if(userStr) {
            const user = JSON.parse(userStr);
            document.getElementById('userName').innerText = "Hola, " + user.name;
            
            fetch('/api/producers/by-email?email=' + encodeURIComponent(user.email))
            .then(r=>r.json())
            .then(data => {
                // If it's a known producer and is unverified, show holding screen
                if(data.success && data.producer.verified === false) {
                    document.querySelector('.dashboard-container').innerHTML = `
                        <div style="grid-column: 1 / -1; background:white; padding: 5rem 2rem; border-radius:16px; text-align:center; box-shadow:var(--shadow-sm);">
                            <i class="fa-solid fa-clock-rotate-left" style="font-size: 5rem; color:#f39c12; margin-bottom:1.5rem;"></i>
                            <h1 style="color:#333; margin-bottom:1rem; font-family:'Outfit';">Cuenta en Revisión</h1>
                            <p style="color:gray; font-size:1.2rem; max-width:650px; margin:0 auto; line-height:1.6;">
                                Hemos recibido correctamente tu solicitud de alta en <b>Kilómetro 0</b> y hemos registrado la ubicación de tu finca (<b>${data.producer.locality}</b>). <br><br> 
                                Por motivos de seguridad y calidad técnica de la plataforma, un <b>Administrador</b> evaluará tu Referencia Catastral y tus credenciales de agricultor en las próximas 24/48 horas.<br><br>
                                Recarga esta página más adelante. Una vez aprobada, tendrás acceso integral a tu catálogo y generador de envíos locales.
                            </p>
                        </div>
                    `;
                }
            });
        } else {
            window.location.href = '/login';
        }

        function logoutProducer() {
            localStorage.removeItem('km0_user');
            window.location.href = '/';
        }

        function switchTab(tabId) {
            document.querySelectorAll('.content-panel').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function simulateScan() {
            const code = prompt("Introduce manualmente el código (ej. QR_123456):");
            if(code) {
                document.getElementById('scanText').innerText = "Verificando...";
                setTimeout(() => {
                    alert("¡Código " + code + " válido! Transacción completada.");
                    document.getElementById('scanText').innerText = "Haz clic para Simular Escaneo";
                }, 1000);
            }
        }
    </script>
</body>
</html>
