<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kilómetro 0 | Panel de Productor</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f0f2f5; }
        .dashboard-container { max-width: 1000px; margin: 3rem auto; display: grid; grid-template-columns: 300px 1fr; gap: 2rem; padding: 0 1rem; }
        .menu-bar { background: linear-gradient(180deg, #1a7a3a 0%, #145a2b 100%); padding: 2rem 1.5rem; border-radius: 16px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 1rem; }
        .menu-item { padding: 1rem; border-radius: 8px; cursor: pointer; transition: 0.3s; font-weight: 600; color: rgba(255,255,255,0.75); display: flex; align-items: center; gap: 10px; }
        .menu-item:hover, .menu-item.active { background: rgba(255,255,255,0.2); color: white; }
        
        .content-area { background: white; padding: 2rem; border-radius: 16px; box-shadow: var(--shadow-sm); min-height: 500px; }
        .content-panel { display: none; }
        .content-panel.active { display: block; animation: fadeIn 0.4s ease; }
        
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        .form-group { margin-bottom: 1.5rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; font-weight: 600; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 0.8rem; border: 1px solid #ccc; border-radius: 8px; font-family: 'Inter'; }
        
        .qr-scanner-box { border: 2px dashed var(--primary); padding: 3rem; text-align: center; border-radius: 12px; margin-top: 2rem; cursor: pointer; transition: 0.3s; background: rgba(46,204,113,0.05); }
        .qr-scanner-box:hover { background: rgba(46,204,113,0.1); }
        
        .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
        .stat-card { background: rgba(46,204,113,0.05); border: 1px solid rgba(46,204,113,0.2); padding: 1.5rem; border-radius: 12px; text-align: center; }
        .stat-card h3 { font-size: 2rem; color: var(--primary); margin-bottom: 0.5rem; }
        .stat-card p { margin: 0; color: var(--text-light); font-weight: 600; font-size: 0.9rem; }

        .product-row { box-shadow: none; border: 1px solid #ddd; flex-direction: row; align-items: center; background: white; border-radius: 12px; padding: 1rem; display: flex; gap: 1rem; margin-bottom: 1rem; transition: 0.3s; }
        .product-row:hover { border-color: var(--primary); }

        .modal-overlay { position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:5000; display:none; justify-content:center; align-items:center; backdrop-filter:blur(3px); }
        .modal-overlay.open { display:flex; }
        .modal-box { background:white; padding:2rem; border-radius:16px; width:100%; max-width:500px; box-shadow: var(--shadow-md); }
    </style>
</head>
<body>
    <nav class="navbar" style="position:static; background:linear-gradient(90deg, #1a7a3a, #145a2b);">
        <div class="logo" style="color:white;">
            <i class="fa-solid fa-tractor" style="color:#8fff8f;"></i>
            <span style="color:white;">Portal Productor</span>
        </div>
        <div class="nav-links">
            <span style="font-weight:600; margin-right:1rem; color:white;"><%= producer.name %></span>
            <button onclick="doLogout()" class="btn btn-outline" style="border-color:rgba(255,255,255,0.5); color:white;">Cerrar Sesión</button>
        </div>
    </nav>

    <% if(!producer.verified) { %>
        <div class="dashboard-container">
            <div style="grid-column: 1 / -1; background:white; padding: 5rem 2rem; border-radius:16px; text-align:center; box-shadow:var(--shadow-sm);">
                <i class="fa-solid fa-clock-rotate-left" style="font-size: 5rem; color:#f39c12; margin-bottom:1.5rem;"></i>
                <h1 style="color:#333; margin-bottom:1rem; font-family:'Outfit';">Cuenta en Revisión</h1>
                <p style="color:gray; font-size:1.2rem; max-width:650px; margin:0 auto; line-height:1.6;">
                    Hemos recibido correctamente tu solicitud de alta en <b>Kilómetro 0</b> y hemos registrado la ubicación de tu finca (<b><%= producer.locality %></b>). <br><br> 
                    Un <b>Administrador</b> evaluará tu Referencia Catastral y tus credenciales de agricultor en las próximas 24/48 horas.<br><br>
                    Recarga esta página más adelante. Una vez aprobada, tendrás acceso integral a tu catálogo.
                </p>
            </div>
        </div>
    <% } else { %>
    <div class="dashboard-container">
        <div class="menu-bar">
            <div style="text-align:center; margin-bottom:1rem;">
                <% if(producer.profileImage) { %>
                    <img src="<%= producer.profileImage %>" style="width:80px; height:80px; border-radius:50%; object-fit:cover; border:3px solid rgba(255,255,255,0.3);">
                <% } else { %>
                    <div style="width:80px; height:80px; border-radius:50%; background:rgba(255,255,255,0.15); display:flex; align-items:center; justify-content:center; margin:0 auto; font-size:2rem; color:white;"><i class="fa-solid fa-tractor"></i></div>
                <% } %>
                <p style="color:rgba(255,255,255,0.7); font-size:0.85rem; margin-top:8px;"><%= producer.locality %></p>
            </div>
            <div class="menu-item active" onclick="switchTab('tab-products')"><i class="fa-solid fa-boxes-stacked"></i> Mis Packs</div>
            <div class="menu-item" onclick="switchTab('tab-profile')"><i class="fa-solid fa-image"></i> Perfil de Granja</div>
            <div class="menu-item" onclick="switchTab('tab-orders')"><i class="fa-solid fa-receipt"></i> Mis Pedidos</div>
            <div class="menu-item" onclick="switchTab('tab-scan')"><i class="fa-solid fa-qrcode"></i> Escanear Recogida</div>
            <div class="menu-item" onclick="window.location.href='/'" style="margin-top:2rem;"><i class="fa-solid fa-arrow-left"></i> Ver Tienda</div>
        </div>

        <div class="content-area">
            <!-- TAB: Products -->
            <div id="tab-products" class="content-panel active">
                <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #eee; padding-bottom:1rem; margin-bottom:1.5rem;">
                    <h2>Mis Packs de Productos</h2>
                    <button class="btn btn-primary" onclick="openAddProductModal()">+ Crear Pack</button>
                </div>
                
                <div class="stats-grid">
                    <div class="stat-card"><h3><%= stats.totalSales %></h3><p>Ventas</p></div>
                    <div class="stat-card"><h3><%= stats.totalRevenue.toFixed(0) %>€</h3><p>Ingresos</p></div>
                    <div class="stat-card"><h3><%= stats.pendingOrders %></h3><p>Pendientes</p></div>
                </div>

                <div id="productsList">
                    <% products.forEach(function(p) { %>
                        <div class="product-row" id="product-row-<%= p.id %>">
                            <img src="<%= p.image_url %>" style="width:80px; height:80px; border-radius:8px; object-fit:cover;" alt="">
                            <div style="flex:1;">
                                <h4 style="margin:0;"><%= p.name %></h4>
                                <p style="margin:0;color:gray; font-size:0.85rem;"><%= p.category %> · <%= p.kg %>kg · Recogida: <%= p.pickup_day %></p>
                            </div>
                            <div style="font-weight:bold; color:var(--primary); font-size: 1.2rem; margin-right:1rem;"><%= p.price.toFixed(2) %>€</div>
                            <button class="btn btn-outline" style="padding:0.4rem 0.8rem; font-size:0.8rem; color:red; border-color:red;" onclick="deleteProduct(<%= p.id %>)"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    <% }); %>
                    <% if(products.length === 0) { %>
                        <p style="color:gray; text-align:center; padding:3rem;">No has creado ningún pack todavía. ¡Pulsa "Crear Pack" para empezar!</p>
                    <% } %>
                </div>
            </div>

            <!-- TAB: Profile -->
            <div id="tab-profile" class="content-panel">
                <h2>Perfil de Granja / Productor</h2>
                <p style="color:gray; margin-bottom:1.5rem;">Estos datos se mostrarán a los clientes cuando vean tus productos y tu perfil de productor.</p>
                
                <div class="form-group">
                    <label>Foto de Perfil (URL de imagen)</label>
                    <input type="text" id="editProfileImage" value="<%= producer.profileImage || '' %>" placeholder="https://...">
                </div>
                
                <div class="form-group">
                    <label>Historia de la Granja (Storytelling)</label>
                    <textarea id="editHistory" style="height:150px; resize:vertical;" placeholder="Cuéntale a tus clientes quién eres y cómo trabajas..."><%= producer.history || '' %></textarea>
                </div>
                
                <button class="btn btn-primary" onclick="saveProfile()"><i class="fa-solid fa-floppy-disk"></i> Guardar Perfil</button>
                <span id="profileMsg" style="margin-left:1rem; color:var(--primary); font-weight:600; display:none;">¡Guardado!</span>
            </div>

            <!-- TAB: Orders -->
            <div id="tab-orders" class="content-panel">
                <h2 style="margin-bottom:1.5rem;">Pedidos Recibidos</h2>
                <% if(orders.length === 0) { %>
                    <p style="color:gray; text-align:center; padding:3rem;">Aún no has recibido pedidos.</p>
                <% } else { %>
                    <% orders.forEach(function(o) { %>
                        <div class="product-row">
                            <div style="flex:1;">
                                <h4 style="margin:0;"><i class="fa-solid fa-qrcode" style="color:var(--primary);"></i> <%= o.qr_code %></h4>
                                <p style="margin:2px 0 0; color:gray; font-size:0.85rem;"><%= o.client_email %> · <%= o.items.length %> artículo(s)</p>
                            </div>
                            <div style="text-align:right;">
                                <span style="font-weight:bold; font-size:1.1rem; color:var(--primary);"><%= o.total_price.toFixed(2) %>€</span><br>
                                <span style="font-size:0.8rem; padding:2px 8px; border-radius:12px; background:<%= o.status === 'CANCELLED' ? '#fee' : '#efe' %>; color:<%= o.status === 'CANCELLED' ? 'red' : 'green' %>;"><%= o.status %></span>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>

            <!-- TAB: QR Scan -->
            <div id="tab-scan" class="content-panel">
                <h2>Verificar Recogida</h2>
                <p>Introduce el código QR que el cliente proporciona para procesar la entrega.</p>
                <div class="form-group" style="margin-top:2rem;">
                    <label>Código de Referencia</label>
                    <div style="display:flex; gap:10px;">
                        <input type="text" id="scanInput" placeholder="QR_1234567890">
                        <button class="btn btn-primary" onclick="verifyScan()"><i class="fa-solid fa-check"></i> Verificar</button>
                    </div>
                </div>
                <div id="scanResult" style="margin-top:1rem;"></div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Modal: Add Product -->
    <div class="modal-overlay" id="addProductModal">
        <div class="modal-box">
            <h2 style="margin-bottom:1.5rem;"><i class="fa-solid fa-plus-circle" style="color:var(--primary);"></i> Crear Nuevo Pack</h2>
            <div class="form-group"><label>Nombre del producto</label><input type="text" id="newName" placeholder="Ej: Tomates Rosa 5kg"></div>
            <div style="display:flex; gap:1rem;">
                <div class="form-group" style="flex:1"><label>Categoría</label>
                    <select id="newCategory"><option>Verduras</option><option>Frutas</option><option>Carnes</option><option>Lácteos</option><option>Miel</option><option>Bebidas</option><option>Otros</option></select>
                </div>
                <div class="form-group" style="flex:1"><label>Precio (€)</label><input type="number" id="newPrice" step="0.5" min="0.5" placeholder="12.50"></div>
            </div>
            <div style="display:flex; gap:1rem;">
                <div class="form-group" style="flex:1"><label>Peso (kg)</label><input type="number" id="newKg" step="0.1" min="0.1" value="1" placeholder="5"></div>
                <div class="form-group" style="flex:1"><label>Día de Recogida</label><input type="text" id="newPickup" placeholder="Viernes"></div>
            </div>
            <div class="form-group"><label>URL de Imagen</label><input type="text" id="newImage" placeholder="https://images.unsplash.com/..."></div>
            <div style="display:flex; gap:1rem; justify-content:flex-end;">
                <button class="btn btn-outline" onclick="closeAddProductModal()">Cancelar</button>
                <button class="btn btn-primary" onclick="submitNewProduct()"><i class="fa-solid fa-check"></i> Crear Pack</button>
            </div>
        </div>
    </div>

    <script>
        function doLogout() {
            fetch('/api/logout', { method: 'POST' }).then(() => {
                localStorage.removeItem('km0_user');
                window.location.href = '/';
            });
        }

        function switchTab(tabId, updateHistory = true) {
            document.querySelectorAll('.content-panel').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            const panel = document.getElementById(tabId);
            if (panel) panel.classList.add('active');
            const menuItem = document.querySelector(`[onclick*="switchTab('${tabId}')"]`);
            if (menuItem) menuItem.classList.add('active');
            if (updateHistory) history.pushState({ tab: tabId }, '', '#' + tabId);
        }

        window.addEventListener('popstate', (event) => {
            const tab = (event.state && event.state.tab) || window.location.hash.substring(1) || 'tab-products';
            if(document.getElementById(tab)) switchTab(tab, false);
        });

        window.addEventListener('DOMContentLoaded', () => {
            const hash = window.location.hash.substring(1);
            if (hash && document.getElementById(hash)) switchTab(hash, false);
            else history.replaceState({ tab: 'tab-products' }, '', '#tab-products');
        });

        // ── Profile Save ────────────────────────────────────────
        function saveProfile() {
            fetch('/api/producers/update-profile', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    profileImage: document.getElementById('editProfileImage').value,
                    history: document.getElementById('editHistory').value
                })
            }).then(r => r.json()).then(data => {
                if(data.success) {
                    const msg = document.getElementById('profileMsg');
                    msg.style.display = 'inline';
                    setTimeout(() => msg.style.display = 'none', 3000);
                }
            });
        }

        // ── Add Product Modal ───────────────────────────────────
        function openAddProductModal() { document.getElementById('addProductModal').classList.add('open'); }
        function closeAddProductModal() { document.getElementById('addProductModal').classList.remove('open'); }

        function submitNewProduct() {
            const name = document.getElementById('newName').value;
            const price = document.getElementById('newPrice').value;
            if(!name || !price) return alert('Nombre y precio son obligatorios');

            fetch('/api/products/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name,
                    category: document.getElementById('newCategory').value,
                    price: parseFloat(price),
                    kg: parseFloat(document.getElementById('newKg').value) || 1,
                    pickup_day: document.getElementById('newPickup').value || 'Consultar',
                    image_url: document.getElementById('newImage').value || ''
                })
            }).then(r => r.json()).then(data => {
                if(data.success) {
                    closeAddProductModal();
                    window.location.reload(); // reload to show new product
                }
            });
        }

        // ── Delete Product ──────────────────────────────────────
        function deleteProduct(id) {
            if(!confirm('¿Estás seguro de eliminar este producto?')) return;
            fetch('/api/products/' + id, { method: 'DELETE' })
            .then(r => r.json()).then(data => {
                if(data.success) {
                    document.getElementById('product-row-' + id).remove();
                }
            });
        }

        // ── QR Verification ────────────────────────────────────
        function verifyScan() {
            const code = document.getElementById('scanInput').value.trim();
            if(!code) return;
            document.getElementById('scanResult').innerHTML = `
                <div style="padding:1.5rem; border-radius:12px; background:#f0fff0; border:1px solid #2ecc71; text-align:center;">
                    <i class="fa-solid fa-circle-check" style="font-size:2.5rem; color:var(--primary); margin-bottom:0.5rem;"></i>
                    <h3 style="color:var(--primary);">¡Código ${code} verificado!</h3>
                    <p style="color:gray;">Transacción completada con éxito. El cliente puede recoger su pedido.</p>
                </div>`;
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
