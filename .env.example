# ── Servidor ────────────────────────────────────────────────────
PORT=3000

# ── JWT ──────────────────────────────────────────────────────────
# Cambia este valor por una cadena larga y aleatoria en producción
JWT_SECRET=supersecretjwtkey_km0_cambiame

# ── PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=km0_db
DB_USER=km0_user
DB_PASSWORD=km0_password

# ── SMTP (Email) ─────────────────────────────────────────────────
# Si dejas estas variables vacías, se usará Ethereal (modo test, no llega a buzones reales).
# Los links de preview del email se mostrarán en la consola del servidor.

# Opción A: Gmail (requiere "Contraseña de aplicación" en Cuenta Google → Seguridad)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=tu_correo@gmail.com
#SMTP_PASS=xxxx xxxx xxxx xxxx

# Opción B: Brevo / Sendinblue (gratis hasta 300 emails/día — brevo.com)
#SMTP_HOST=smtp-relay.brevo.com
#SMTP_PORT=587
#SMTP_USER=tu_correo@brevo.com
#SMTP_PASS=tu_clave_smtp_brevo

# Opción C: Outlook / Hotmail
#SMTP_HOST=smtp-mail.outlook.com
#SMTP_PORT=587
#SMTP_USER=tu_correo@outlook.com
#SMTP_PASS=tu_contraseña

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
