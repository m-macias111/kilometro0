PORT=3000
DATABASE_URL=postgres://km0_user:km0_password@localhost:5432/km0_db
JWT_SECRET=supersecretjwtkey_km0

# ── SMTP para enviar emails REALES ──────────────────────────────
# Opción A: Gmail (necesitas "Contraseña de aplicación" de Google)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tu_correo@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx   (contraseña de app, NO tu contraseña normal)

# Opción B: Brevo / Sendinblue (gratis, 300 emails/día, regístrate en brevo.com)
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=tu_correo@registrado_en_brevo.com
#   SMTP_PASS=tu_smtp_key_de_brevo

# Opción C: Outlook / Hotmail
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USER=tu_correo@outlook.com
#   SMTP_PASS=tu_contraseña

# ── DESCOMENTA UNA de las opciones de arriba y rellena tus datos ──
# Si no configuras nada, el servidor usará Ethereal (modo pruebas, no llega a buzones reales).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
